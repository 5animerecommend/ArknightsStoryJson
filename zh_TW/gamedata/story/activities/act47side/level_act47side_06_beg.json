{"lang": "zh_TW", "eventid": "act47side", "eventName": "未許之地", "entryType": "ACTIVITY", "storyCode": "UR-6", "avgTag": "行動前", "storyName": "交叉航線", "storyInfo": "娜斯提見到了錫人，得知梅蘭德計劃讓萊茵為這次事故頂罪，娜斯提最終選擇由她獨自承擔。拂哀菈聽到娜斯提被定罪的消息，陷入了回憶。\n", "storyList": [{"id": 0, "prop": "HEADER", "attributes": {"key": "title_test", "is_skippable": "true", "fit_mode": "BLACK_MASK"}}, {"id": 1, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 2, "prop": "stopmusic", "attributes": {}}, {"id": 3, "prop": "Dialog", "attributes": {}}, {"id": 4, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 5, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "fadetime": 0.0, "keep": "true", "initamount": 0.0, "amount": 1.0, "block": "true"}}, {"id": 6, "prop": "Background", "attributes": {"image": "29_g1_outdoorbase", "screenadapt": "coverall"}}, {"id": 7, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 8, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 9, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2032_1#1$1", "duration": 1.5}}, {"id": 10, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 11, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "fadetime": 2.0, "amount": 0.0, "block": "true"}}, {"id": 12, "prop": "name", "attributes": {"content": "……", "name": "娜斯提"}, "figure_art": "avg_npc_2032_1#1$1"}, {"id": 13, "prop": "Dialog", "attributes": {}}, {"id": 14, "prop": "playsound", "attributes": {"key": "$d_avg_wind"}}, {"id": 15, "prop": "playMusic", "attributes": {"key": "$calm_loop", "volume": 0.6}}, {"id": 16, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 17, "prop": "name", "attributes": {"content": "風吹動年輕女妖手中的樹葉，聲音從其間掉落。"}}, {"id": 18, "prop": "playsound", "attributes": {"key": "$d_avg_childrenlaugh", "volume": 0.3}}, {"id": 19, "prop": "playsound", "attributes": {"key": "$d_avg_warmbonfire_loop", "loop": "true", "channel": "f", "volume": 0.3}}, {"id": 20, "prop": "name", "attributes": {"content": "（薩卡茲語）再講一個，再講一個！", "name": "河谷孩子們的聲音"}}, {"id": 21, "prop": "name", "attributes": {"content": "（薩卡茲語）想不想聽鐵皮遊俠的故事？", "name": "拂哀菈的聲音"}}, {"id": 22, "prop": "name", "attributes": {"content": "（薩卡茲語）他還來過我們的河谷呢。如今籠罩著霧湖的霧，最早就是從他的大菸斗裡飄出來的……", "name": "拂哀菈的聲音"}}, {"id": 23, "prop": "StopSound", "attributes": {"channel": "f", "fadetime": 2.0}}, {"id": 24, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2032_1#6$1"}}, {"id": 25, "prop": "name", "attributes": {"content": "……", "name": "娜斯提"}, "figure_art": "avg_npc_2032_1#6$1"}, {"id": 26, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 27, "prop": "playsound", "attributes": {"key": "$d_avg_magic_4", "volume": 0.5}}, {"id": 28, "prop": "name", "attributes": {"content": "（薩卡茲語）這樣，就能讓羽角收攏，遮住你的雙眼。", "name": "菈瑪蓮的聲音"}}, {"id": 29, "prop": "name", "attributes": {"content": "（薩卡茲語）為了白天睡覺的時候當眼罩用？", "name": "哀琺尼爾的聲音"}}, {"id": 30, "prop": "name", "attributes": {"content": "（薩卡茲語）不是，當然不是。是為了你在葬儀上流淚時，能從容地將那淚水編織成輓歌……", "name": "菈瑪蓮的聲音"}}, {"id": 31, "prop": "name", "attributes": {"content": "又一段聲音播放完畢，年輕的女妖將葉片收進了懷裡，她的眼神瞬間變得充滿警戒。"}}, {"id": 32, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 33, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2032_1#2$1"}}, {"id": 34, "prop": "name", "attributes": {"content": "再偷聽的話，我會把你丟進混凝土攪拌機裡。", "name": "娜斯提"}, "figure_art": "avg_npc_2032_1#2$1"}, {"id": 35, "prop": "Dialog", "attributes": {}}, {"id": 36, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 37, "prop": "Image", "attributes": {"image": "68_i16", "xScale": 1.4, "yScale": 1.4, "screenadapt": "coverall", "x": 250.0, "fadetime": 2.0}}, {"id": 38, "prop": "playMusic", "attributes": {"key": "$DecisiveBattle_loop", "volume": 0.6}}, {"id": 39, "prop": "ImageTween", "attributes": {"xTo": 100.0, "duration": 60.0}}, {"id": 40, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 41, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 42, "prop": "Background", "attributes": {}}, {"id": 43, "prop": "name", "attributes": {"content": "剛剛那是……女妖的咒言？", "name": "克麗斯騰"}}, {"id": 44, "prop": "name", "attributes": {"content": "是。", "name": "娜斯提"}}, {"id": 45, "prop": "name", "attributes": {"content": "哥倫比亞與卡茲戴爾遠隔千里，你走了這麼遠的路，卻將族人的聲音刻錄下來隨身攜帶，反反覆覆地聆聽？", "name": "克麗斯騰"}}, {"id": 46, "prop": "name", "attributes": {"content": "思鄉，很難理解？", "name": "娜斯提"}}, {"id": 47, "prop": "name", "attributes": {"content": "……不難。但我確實很少看到一個人思鄉時表情專注得像在看圖紙。", "name": "克麗斯騰"}}, {"id": 48, "prop": "name", "attributes": {"content": "你在試圖解讀女妖的語言與行為模式，為什麼？為了尋找一條足以改變整個族群幾千年來生存困境的新路徑？", "name": "克麗斯騰"}}, {"id": 49, "prop": "name", "attributes": {"content": "你……", "name": "娜斯提"}}, {"id": 50, "prop": "name", "attributes": {"content": "我沒那麼自命不凡。", "name": "娜斯提"}}, {"id": 51, "prop": "name", "attributes": {"content": "我只是，希望能讓一個愛操心的傢伙餘生不那麼有負擔。", "name": "娜斯提"}}, {"id": 52, "prop": "name", "attributes": {"content": "理解，雖然聽起來是同一件事情。", "name": "克麗斯騰"}}, {"id": 53, "prop": "name", "attributes": {"content": "請問有突破了嗎？", "name": "克麗斯騰"}}, {"id": 54, "prop": "name", "attributes": {"content": "我不至於那麼急躁。", "name": "娜斯提"}}, {"id": 55, "prop": "name", "attributes": {"content": "聽起來，你已經把那些錄音聽過成百上千遍……", "name": "克麗斯騰"}}, {"id": 56, "prop": "name", "attributes": {"content": "……", "name": "娜斯提"}}, {"id": 57, "prop": "name", "attributes": {"content": "老是泡在同一個語料庫裡，直到溺死，也發明不出一種新的語言。", "name": "克麗斯騰"}}, {"id": 58, "prop": "name", "attributes": {"content": "目光與思維的局限會讓我們溺死在“常識”裡，然後一切都將變成所謂的“命運”……", "name": "克麗斯騰"}}, {"id": 59, "prop": "name", "attributes": {"content": "我以為你正是意識到了這一點，才離開卡茲戴爾的。", "name": "克麗斯騰"}}, {"id": 60, "prop": "name", "attributes": {"content": "刪除那些錄音……一個殘忍的建議。", "name": "克麗斯騰"}}, {"id": 61, "prop": "name", "attributes": {"content": "很合理。", "name": "娜斯提"}}, {"id": 62, "prop": "name", "attributes": {"content": "你好，我叫克麗斯騰，萊茵生命的總轄。", "name": "克麗斯騰"}}, {"id": 63, "prop": "name", "attributes": {"content": "娜斯提。", "name": "娜斯提"}}, {"id": 64, "prop": "name", "attributes": {"content": "斯特萊建築公司新招的天才工程師，只需要旁人三分之一的時間便能完成工程的女妖，業內人都在傳你的圖紙上附著了巫術……", "name": "克麗斯騰"}}, {"id": 65, "prop": "name", "attributes": {"content": "萊茵生命正在籌建工程科，或許你會有興趣？", "name": "克麗斯騰"}}, {"id": 66, "prop": "name", "attributes": {"content": "我昨天無意中聽到了你和老闆聊天……“萊茵生命”，是一家涉及生物技術的科技公司？", "name": "娜斯提"}}, {"id": 67, "prop": "name", "attributes": {"content": "娜斯提，抬頭……看見那些羽獸和牠們背後的晨星了嗎？", "name": "克麗斯騰"}}, {"id": 68, "prop": "name", "attributes": {"content": "我只是在尋找一種能讓我們突破天空的力量。", "name": "克麗斯騰"}}, {"id": 69, "prop": "name", "attributes": {"content": "天空……", "name": "娜斯提"}}, {"id": 70, "prop": "name", "attributes": {"content": "正如你剛剛的建議，如果要做的事情已經超越了常識，你需要的力量或許也並不來自我們身邊……", "name": "娜斯提"}}, {"id": 71, "prop": "name", "attributes": {"content": "萊茵生命更應該籌建的是科學考察科。", "name": "娜斯提"}}, {"id": 72, "prop": "name", "attributes": {"content": "很合理。我可以將這視作工程科主任給公司的第一條建議？", "name": "克麗斯騰"}}, {"id": 73, "prop": "Dialog", "attributes": {}}, {"id": 74, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 75, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "fadetime": 2.0, "keep": "true", "initamount": 0.0, "amount": 0.7, "block": "true"}}, {"id": 76, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 77, "prop": "charslot", "attributes": {}}, {"id": 78, "prop": "image", "attributes": {}}, {"id": 79, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 80, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "fadetime": 0.0, "amount": 0.0, "block": "true"}}, {"id": 81, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4212_nasti_1#9$1"}}, {"id": 82, "prop": "Background", "attributes": {"image": "68_g5_floatingstation", "screenadapt": "coverall"}}, {"id": 83, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 84, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 85, "prop": "name", "attributes": {"content": "……", "name": "娜斯提"}, "figure_art": "avg_4212_nasti_1#9$1"}, {"id": 86, "prop": "playMusic", "attributes": {"intro": "$darkness01_intro", "key": "$darkness01_loop", "volume": 0.6}}, {"id": 87, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2046_1#1$1"}}, {"id": 88, "prop": "name", "attributes": {"content": "娜斯提女士？", "name": "協會成員"}, "figure_art": "avg_npc_2046_1#1$1"}, {"id": 89, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4212_nasti_1#1$1"}}, {"id": 90, "prop": "name", "attributes": {"content": "我以為你們會直接把我押去聽證會的現場，或者其他更隱密的監獄……而我們此刻卻在纜車站等纜車，看樣子接下來是要參觀浮空層？", "name": "娜斯提"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 91, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2046_1#1$1"}}, {"id": 92, "prop": "name", "attributes": {"content": "想見你的那個人，確實是這樣安排的。", "name": "協會成員"}, "figure_art": "avg_npc_2046_1#1$1"}, {"id": 93, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4212_nasti_1#1$1"}}, {"id": 94, "prop": "name", "attributes": {"content": "……", "name": "娜斯提"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 95, "prop": "Dialog", "attributes": {}}, {"id": 96, "prop": "charslot", "attributes": {}}, {"id": 97, "prop": "playsound", "attributes": {"key": "$d_avg_cablecar_loop", "loop": "true", "channel": "bgs"}}, {"id": 98, "prop": "StopSound", "attributes": {"channel": "bgs", "fadetime": 2.0}}, {"id": 99, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 100, "prop": "playsound", "attributes": {"key": "$d_avg_cablecar_arrive"}}, {"id": 101, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 102, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4151_tinman_1#1$1", "duration": 1.0}}, {"id": 103, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 104, "prop": "name", "attributes": {"content": "好久不見，娜斯提。", "name": "錫人"}, "figure_art": "avg_4151_tinman_1#1$1"}, {"id": 105, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4212_nasti_1#1$1"}}, {"id": 106, "prop": "name", "attributes": {"content": "……原來是你。", "name": "娜斯提"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 107, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4151_tinman_1#1$1"}}, {"id": 108, "prop": "name", "attributes": {"content": "我剛到沒多久，這裡真是個好地方啊。我還差一半沒有逛完，陪我一起？", "name": "錫人"}, "figure_art": "avg_4151_tinman_1#1$1"}, {"id": 109, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4212_nasti_1#1$1"}}, {"id": 110, "prop": "name", "attributes": {"content": "也好。", "name": "娜斯提"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 111, "prop": "Dialog", "attributes": {}}, {"id": 112, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 113, "prop": "charslot", "attributes": {}}, {"id": 114, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 115, "prop": "Background", "attributes": {"image": "68_g6_floatinglabmodule", "screenadapt": "coverall"}}, {"id": 116, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 117, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 118, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_4212_nasti_1#1$1", "duration": 1.0}}, {"id": 119, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_4151_tinman_1#10$1", "duration": 1.0}}, {"id": 120, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 121, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_4151_tinman_1#10$1", "focus": "r"}}, {"id": 122, "prop": "name", "attributes": {"content": "……為什麼只有我們剛剛穿過的區域在下雨？", "name": "錫人"}}, {"id": 123, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_4212_nasti_1#1$1", "focus": "l"}}, {"id": 124, "prop": "name", "attributes": {"content": "雲端影棚。藍卡塢開發了一套即時天空造景系統，再等五分鐘，你甚至可以看到極光。", "name": "娜斯提"}}, {"id": 125, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_4151_tinman_1#1$1", "focus": "r"}}, {"id": 126, "prop": "name", "attributes": {"content": "一百年前，那個被如今的人稱作攝影之父的傢伙在片場跟我感慨，說要是未來真的能在天上拍電影就好了……", "name": "錫人"}}, {"id": 127, "prop": "name", "attributes": {"content": "“天空熱”還真的推動了電影技術革命啊。", "name": "錫人"}}, {"id": 128, "prop": "name", "attributes": {"content": "這裡真熱鬧，娜斯提。我自認為早就對生活的日新月異習以為常，此刻也不得不感慨哥倫比亞人的創造力。", "name": "錫人"}}, {"id": 129, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_4212_nasti_1#1$1", "focus": "l"}}, {"id": 130, "prop": "name", "attributes": {"content": "很難想像此時此刻你還有這樣的閒情逸致。", "name": "娜斯提"}}, {"id": 131, "prop": "name", "attributes": {"content": "按照特區政府專為“螺旋槳天堂”制定的管理法案，緊急事件發生後的十二小時內，相關部門必須召開聽證會，處理並公告調查結果。", "name": "娜斯提"}}, {"id": 132, "prop": "name", "attributes": {"content": "高登闖入萊茵的生態園，破壞了我們的正在進行的研究計劃，還順便把他那些見不得光的生意暴露在了世人面前。", "name": "娜斯提"}}, {"id": 133, "prop": "name", "attributes": {"content": "整件事情的證據鏈完整且確鑿，你們很快來到了園區，卻一直在拖延聽證會召開的時間……", "name": "娜斯提"}}, {"id": 134, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_4151_tinman_1#1$1", "focus": "r"}}, {"id": 135, "prop": "name", "attributes": {"content": "這並不是拖延，娜斯提。", "name": "錫人"}}, {"id": 136, "prop": "name", "attributes": {"content": "兩年前，哥倫比亞人絕不會想到自己有一天會和天上的雲爭搶居住權。但如今呢？", "name": "錫人"}}, {"id": 137, "prop": "name", "attributes": {"content": "“螺旋槳天堂”已經成為整個哥倫比亞最受關注的存在，特殊地塊備案名錄裡，它的名字被移到了第一頁。", "name": "錫人"}}, {"id": 138, "prop": "name", "attributes": {"content": "花上一點時間，坐纜車逛一圈，看看身邊的這些設施，看看堵在註冊中心門口的公司代表們……", "name": "錫人"}}, {"id": 139, "prop": "name", "attributes": {"content": "這所有的一切已經告訴了我們，聽證會需要給出怎樣的結論，不是嗎？", "name": "錫人"}}, {"id": 140, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_4212_nasti_1#1$1", "focus": "l"}}, {"id": 141, "prop": "name", "attributes": {"content": "……", "name": "娜斯提"}}, {"id": 142, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_4151_tinman_1#1$1", "focus": "r"}}, {"id": 143, "prop": "name", "attributes": {"content": "“螺旋槳天堂”，嘖，聽聽，“天堂”代表扶搖直上的狂熱野心，而“螺旋槳”的意思也很明確——絕不能停下來。", "name": "錫人"}}, {"id": 144, "prop": "name", "attributes": {"content": "走私網路曝光，總長官主導，涉及近百家進駐企業，園區這半年的研究工作存在諸多違法之處……一旦徹查，接下來的展覽便不得不喊卡。", "name": "錫人"}}, {"id": 145, "prop": "name", "attributes": {"content": "你說得沒錯，娜斯提，聽證會必須召開，這段時間的所有意外都必須要有一個交代——", "name": "錫人"}}, {"id": 146, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_4212_nasti_1#1$1", "focus": "l"}}, {"id": 147, "prop": "name", "attributes": {"content": "但也只是一個交代而已。", "name": "娜斯提"}}, {"id": 148, "prop": "name", "attributes": {"content": "而“萊茵生命”是那個最適合不過的交代？", "name": "娜斯提"}}, {"id": 149, "prop": "name", "attributes": {"content": "畢竟，這場“天空熱”，本就是從特里蒙的那個夜晚開始。因為這前科，幾乎不會有任何人質疑萊茵的再犯。", "name": "娜斯提"}}, {"id": 150, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_4151_tinman_1#1$1", "focus": "r"}}, {"id": 151, "prop": "name", "attributes": {"content": "唉，你從來都不像同行傳言的那般，是個只知道埋頭接電纜的技術工。", "name": "錫人"}}, {"id": 152, "prop": "name", "attributes": {"content": "不過，萊茵也並不冤枉，不是嗎？", "name": "錫人"}}, {"id": 153, "prop": "name", "attributes": {"content": "你們那棵來歷不明的“樹”還飄在天上，拋開“種植單元”之類的說辭，你要怎麼向我解釋？", "name": "錫人"}}, {"id": 154, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_4212_nasti_1#5$1", "focus": "l"}}, {"id": 155, "prop": "name", "attributes": {"content": "……", "name": "娜斯提"}}, {"id": 156, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_4212_nasti_1#1$1", "focus": "l"}}, {"id": 157, "prop": "name", "attributes": {"content": "聽起來，我已經不用去聽證會的現場了，畢竟你們早就做好了決定。", "name": "娜斯提"}}, {"id": 158, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_4151_tinman_1#2$1", "focus": "r"}}, {"id": 159, "prop": "name", "attributes": {"content": "……抱歉，娜斯提。", "name": "錫人"}}, {"id": 160, "prop": "Dialog", "attributes": {}}, {"id": 161, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 162, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 163, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 164, "prop": "charslot", "attributes": {}}, {"id": 165, "prop": "Background", "attributes": {}}, {"id": 166, "prop": "Image", "attributes": {"image": "68_i16", "screenadapt": "coverall"}}, {"id": 167, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 168, "prop": "playMusic", "attributes": {"key": "$DecisiveBattle_loop", "volume": 0.6}}, {"id": 169, "prop": "name", "attributes": {"content": "……", "name": "克麗斯騰"}}, {"id": 170, "prop": "name", "attributes": {"content": "雖然並不確定具體的時間，但我終究會回到我的家鄉，有人在等著我。", "name": "娜斯提"}}, {"id": 171, "prop": "name", "attributes": {"content": "但在那之前，萊茵生命可以成為你旅途中的一站。", "name": "克麗斯騰"}}, {"id": 172, "prop": "name", "attributes": {"content": "無論你想發明一種新的語言，建造一個新的河谷，還是改變那所謂的族群的“命運”……都沒有人會干涉。", "name": "克麗斯騰"}}, {"id": 173, "prop": "name", "attributes": {"content": "相反，萊茵生命會為你爭取你所需的一切。畢竟，那裡的很多人都和你很像。", "name": "克麗斯騰"}}, {"id": 174, "prop": "name", "attributes": {"content": "條件呢？或者說……代價是？", "name": "娜斯提"}}, {"id": 175, "prop": "name", "attributes": {"content": "娜斯提，我並不要求公司成員把“萊茵生命”的事業當作某種偉業，為它奉獻或犧牲。", "name": "克麗斯騰"}}, {"id": 176, "prop": "name", "attributes": {"content": "如果我們要做從來都沒有人做過的事情，那便已注定要面對足夠多的懷疑與失去……", "name": "克麗斯騰"}}, {"id": 177, "prop": "name", "attributes": {"content": "所以，永遠都別停下來。", "name": "克麗斯騰"}}, {"id": 178, "prop": "name", "attributes": {"content": "……既然如此，我同意加入萊茵生命。", "name": "娜斯提"}}, {"id": 179, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 180, "prop": "Dialog", "attributes": {}}, {"id": 181, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 182, "prop": "charslot", "attributes": {}}, {"id": 183, "prop": "image", "attributes": {}}, {"id": 184, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_4212_nasti_1#1$1"}}, {"id": 185, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_4151_tinman_1#1$1"}}, {"id": 186, "prop": "Background", "attributes": {"image": "68_g6_floatinglabmodule", "screenadapt": "coverall"}}, {"id": 187, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 188, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 189, "prop": "playMusic", "attributes": {"intro": "$darkness02_intro", "key": "$darkness02_loop", "volume": 0.6}}, {"id": 190, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_4212_nasti_1#1$1", "focus": "l"}}, {"id": 191, "prop": "name", "attributes": {"content": "你我還在纜車上，說明事情還有可談的餘地，對吧？", "name": "娜斯提"}}, {"id": 192, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_4151_tinman_1#1$1", "focus": "r"}}, {"id": 193, "prop": "name", "attributes": {"content": "嗯哼？", "name": "錫人"}}, {"id": 194, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_4212_nasti_1#1$1", "focus": "l"}}, {"id": 195, "prop": "name", "attributes": {"content": "聽證會必須召開，一切都必須有個交代，但也只是一個交代而已……", "name": "娜斯提"}}, {"id": 196, "prop": "name", "attributes": {"content": "全哥倫比亞都知道，兩年前的“地平弧光計畫”，克麗斯騰竊取了國防部的投資，萊茵生命並未完全參與……但我確實是她的共犯。", "name": "娜斯提"}}, {"id": 197, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_4151_tinman_1#5$1", "focus": "r"}}, {"id": 198, "prop": "name", "attributes": {"content": "危及整個園區的罪責，由一家公司承擔，還是由個人承擔，性質截然不同。娜斯提，你願意為萊茵生命犧牲到這個地步？", "name": "錫人"}}, {"id": 199, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_4212_nasti_1#2$1", "focus": "l"}}, {"id": 200, "prop": "name", "attributes": {"content": "犧牲？我和克麗斯騰都不喜歡這個詞。", "name": "娜斯提"}}, {"id": 201, "prop": "name", "attributes": {"content": "凡事都有代價，這是卡茲戴爾和河谷的生活教會我的道理。我不可能心甘情願地充當梅蘭德計劃中的代罪羔羊。", "name": "娜斯提"}}, {"id": 202, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_4151_tinman_1#1$1", "focus": "r"}}, {"id": 203, "prop": "name", "attributes": {"content": "……", "name": "錫人"}}, {"id": 204, "prop": "name", "attributes": {"content": "我不會為難萊茵的其他人。", "name": "錫人"}}, {"id": 205, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_4212_nasti_1#2$1", "focus": "l"}}, {"id": 206, "prop": "name", "attributes": {"content": "以及那棵“樹”。", "name": "娜斯提"}}, {"id": 207, "prop": "name", "attributes": {"content": "裝置本身隨你們處置，但請讓我的助理研究員把數據帶走，研究還沒完成。他對我的計劃並不知情，不用擔心他動手腳。", "name": "娜斯提"}}, {"id": 208, "prop": "Dialog", "attributes": {}}, {"id": 209, "prop": "playsound", "attributes": {"key": "$d_avg_cablecar_arrive"}}, {"id": 210, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 211, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_4212_nasti_1#1$1", "focus": "l"}}, {"id": 212, "prop": "name", "attributes": {"content": "到站了。", "name": "娜斯提"}}, {"id": 213, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_4151_tinman_1#1$1", "focus": "r"}}, {"id": 214, "prop": "name", "attributes": {"content": "纜車站的特工會送你去該去的地方。", "name": "錫人"}}, {"id": 215, "prop": "name", "attributes": {"content": "對了，有件事我想問你。之前回卡茲戴爾的時候，我去過一趟河谷……", "name": "錫人"}}, {"id": 216, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_4212_nasti_1#1$1", "focus": "l"}}, {"id": 217, "prop": "name", "attributes": {"content": "拂哀菈來到了這裡……我已經知道了。", "name": "娜斯提"}}, {"id": 218, "prop": "name", "attributes": {"content": "我本來打算在聽證會前，儘快找到她。", "name": "娜斯提"}}, {"id": 219, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_4151_tinman_1#8$1", "focus": "r"}}, {"id": 220, "prop": "name", "attributes": {"content": "（拂哀菈在園區……）", "name": "錫人"}}, {"id": 221, "prop": "name", "attributes": {"content": "（呵，梅希亞，原來如此……）", "name": "錫人"}}, {"id": 222, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_4151_tinman_1#1$1", "focus": "r"}}, {"id": 223, "prop": "name", "attributes": {"content": "我會派人安置我的這位老友。", "name": "錫人"}}, {"id": 224, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_4212_nasti_1#1$1", "focus": "l"}}, {"id": 225, "prop": "name", "attributes": {"content": "謝謝。", "name": "娜斯提"}}, {"id": 226, "prop": "Dialog", "attributes": {}}, {"id": 227, "prop": "playsound", "attributes": {"key": "$d_avg_highheelfts"}}, {"id": 228, "prop": "charslot", "attributes": {"slot": "l", "posfrom": "0,0", "posto": "-200,0", "duration": 1.0, "afrom": 1.0, "ato": 0.0}}, {"id": 229, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 230, "prop": "Dialog", "attributes": {}}, {"id": 231, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 232, "prop": "charslot", "attributes": {}}, {"id": 233, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 234, "prop": "Background", "attributes": {"image": "68_g1_groundparkstreet_d", "screenadapt": "coverall"}}, {"id": 235, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 236, "prop": "playsound", "attributes": {"key": "$d_avg_broadcast_third"}}, {"id": 237, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 238, "prop": "name", "attributes": {"content": "有關“螺旋槳天堂”突發實驗事故的聽證會已於剛剛結束。", "name": "園區廣播"}}, {"id": 239, "prop": "name", "attributes": {"content": "嫌疑人娜斯提·魯諾瑞伊利用園區工程部負責人的職務之便，私自進行未經核准的實驗計劃，差點釀成重大事故。", "name": "園區廣播"}}, {"id": 240, "prop": "Dialog", "attributes": {}}, {"id": 241, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 242, "prop": "charslot", "attributes": {}}, {"id": 243, "prop": "Background", "attributes": {"image": "68_g3_highelevatorplaza", "screenadapt": "coverall"}}, {"id": 244, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 245, "prop": "name", "attributes": {"content": "為掩蓋犯罪事實，事發當晚，嫌疑人利用性質未知的樹形裝置襲擊了正在執法的園區總長官高登·譚農。", "name": "園區廣播"}}, {"id": 246, "prop": "name", "attributes": {"content": "據高登長官所言，除了故意傷害，嫌疑人還涉嫌濫用工程部的展品檢修職權。", "name": "園區廣播"}}, {"id": 247, "prop": "name", "attributes": {"content": "她強迫下屬進行非法檢測，蓄意打壓其他科技公司，迫使幾十家優秀企業撤離園區。", "name": "園區廣播"}}, {"id": 248, "prop": "name", "attributes": {"content": "現在，在煙酒施術單元以及源石製品管理局的支持下，被無辜牽連的企業已回到“螺旋槳天堂”，繼續為哥倫比亞天空事業做貢獻。", "name": "園區廣播"}}, {"id": 249, "prop": "Dialog", "attributes": {}}, {"id": 250, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 251, "prop": "charslot", "attributes": {}}, {"id": 252, "prop": "Background", "attributes": {"image": "68_g4_floatingplatform", "screenadapt": "coverall"}}, {"id": 253, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 254, "prop": "name", "attributes": {"content": "目前，嫌疑人娜斯提·魯諾瑞伊對其犯罪事實供認不諱，已被收押，後續將被送至特區法院接受相應的法律制裁。", "name": "園區廣播"}}, {"id": 255, "prop": "name", "attributes": {"content": "“螺旋槳天堂”的後續運作，將在梅蘭德緊急管理監督協會的監督下，由高登長官和古斯塔夫長官負責……", "name": "園區廣播"}}, {"id": 256, "prop": "Dialog", "attributes": {}}, {"id": 257, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 258, "prop": "charslot", "attributes": {}}, {"id": 259, "prop": "Background", "attributes": {"image": "bg_hotel", "screenadapt": "coverall"}}, {"id": 260, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 261, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 262, "prop": "name", "attributes": {"content": "……萬眾矚目的“天空生活展覽”將不會受到任何影響。", "name": "園區廣播"}}, {"id": 263, "prop": "Dialog", "attributes": {}}, {"id": 264, "prop": "playsound", "attributes": {"key": "$p_imp_funnel_end_h"}}, {"id": 265, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 266, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2037_1#5$1", "duration": 1.0}}, {"id": 267, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 268, "prop": "name", "attributes": {"content": "拂哀菈女士……吵到您了嗎？抱歉。", "name": "梅希亞"}, "figure_art": "avg_npc_2037_1#5$1"}, {"id": 269, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2035_1#9$1"}}, {"id": 270, "prop": "name", "attributes": {"content": "娜斯提……她怎麼了？", "name": "拂哀菈"}, "figure_art": "avg_npc_2035_1#9$1"}, {"id": 271, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2037_1#10$1"}}, {"id": 272, "prop": "name", "attributes": {"content": "……別去想那些了，女士。", "name": "梅希亞"}, "figure_art": "avg_npc_2037_1#10$1"}, {"id": 273, "prop": "name", "attributes": {"content": "就讓您對娜斯提主任的記憶，停留在您昨晚見到她的時候吧。", "name": "梅希亞"}, "figure_art": "avg_npc_2037_1#10$1"}, {"id": 274, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 275, "prop": "name", "attributes": {"content": "年輕的特工將手放在老舊的幻燈機上，輕柔地撥動起轉盤，像是在撥弄纖細的絲線——記憶的絲線。"}}, {"id": 276, "prop": "playsound", "attributes": {"key": "$d_avg_filmprojection_loop", "loop": "true", "channel": "f", "volume": 0.0}}, {"id": 277, "prop": "SoundVolume", "attributes": {"volume": 1.0, "channel": "f", "fadetime": 2.0}}, {"id": 278, "prop": "name", "attributes": {"content": "梅蘭德緊急管理監督協會，以監督政府機構緊急管理措施的名義，介入哥倫比亞的一切事故。因為事故，是最易被捏塑的事實。"}}, {"id": 279, "prop": "name", "attributes": {"content": "錫人總是調侃，協會的手段比約翰老媽的貨品清單還要豐富，其中自然也包括梅希亞的源石技藝——"}}, {"id": 280, "prop": "name", "attributes": {"content": "對記憶的抹消。"}}, {"id": 281, "prop": "StopSound", "attributes": {"channel": "f", "fadetime": 0.5}}, {"id": 282, "prop": "name", "attributes": {"content": "同樣的動作，梅希亞已經做過百次、千次。但此刻，她撥動轉盤的手，卻僵在了半空。"}}, {"id": 283, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2037_1#7$1"}}, {"id": 284, "prop": "name", "attributes": {"content": "不……至少不該對一位記憶本就所剩無幾的老人。", "name": "梅希亞"}, "figure_art": "avg_npc_2037_1#7$1"}, {"id": 285, "prop": "name", "attributes": {"content": "況且，今天被竄改的事實已經夠多了。", "name": "梅希亞"}, "figure_art": "avg_npc_2037_1#7$1"}, {"id": 286, "prop": "name", "attributes": {"content": "遲開的聽證會、心滿意足的企業代表、混入人群的特工同事……錫人前輩的任務究竟是什麼？", "name": "梅希亞"}, "figure_art": "avg_npc_2037_1#7$1"}, {"id": 287, "prop": "name", "attributes": {"content": "巡邏的人手越來越多，我能為您做的已經越來越少——前輩發現我的隱瞞只是時間問題。", "name": "梅希亞"}, "figure_art": "avg_npc_2037_1#7$1"}, {"id": 288, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2037_1#10$1"}}, {"id": 289, "prop": "name", "attributes": {"content": "但如果您無論如何都還是放心不下娜斯提主任，我會想想辦法……", "name": "梅希亞"}, "figure_art": "avg_npc_2037_1#10$1"}, {"id": 290, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2035_1#5$1"}}, {"id": 291, "prop": "name", "attributes": {"content": "娜斯提……對不起，我的女兒。", "name": "拂哀菈"}, "figure_art": "avg_npc_2035_1#5$1"}, {"id": 292, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2037_1#8$1"}}, {"id": 293, "prop": "name", "attributes": {"content": "……", "name": "梅希亞"}, "figure_art": "avg_npc_2037_1#8$1"}, {"id": 294, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2035_1#5$1"}}, {"id": 295, "prop": "name", "attributes": {"content": "是我害你……無家可歸。", "name": "拂哀菈"}, "figure_art": "avg_npc_2035_1#5$1"}, {"id": 296, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 297, "prop": "Dialog", "attributes": {}}, {"id": 298, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 299, "prop": "charslot", "attributes": {}}, {"id": 300, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 301, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "fadetime": 0.0, "keep": "true", "initamount": 0.0, "amount": 1.0, "block": "true"}}, {"id": 302, "prop": "Background", "attributes": {"image": "68_g12_valleytree", "screenadapt": "coverall"}}, {"id": 303, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 304, "prop": "playsound", "attributes": {"key": "$d_avg_mnwtrfll", "loop": "true", "channel": "pb", "volume": 0.0}}, {"id": 305, "prop": "SoundVolume", "attributes": {"volume": 0.4, "channel": "pb", "fadetime": 2.0}}, {"id": 306, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "fadetime": 2.0, "amount": 0.0, "block": "true"}}, {"id": 307, "prop": "playsound", "attributes": {"key": "$d_avg_enchantress_sad", "volume": 0.3}}, {"id": 308, "prop": "name", "attributes": {"content": "“炬火之所往，眾魂之所在。”", "name": "拂哀菈"}}, {"id": 309, "prop": "name", "attributes": {"content": "“骨歸於骨，魂歸於魂。”", "name": "拂哀菈"}}, {"id": 310, "prop": "Dialog", "attributes": {}}, {"id": 311, "prop": "StopSound", "attributes": {"channel": "pb", "fadetime": 5.0}}, {"id": 312, "prop": "playMusic", "attributes": {"intro": "$loneliness_intro", "key": "$loneliness_loop", "volume": 0.6}}, {"id": 313, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1071_1#1$1", "duration": 1.0}}, {"id": 314, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_2048_1#8$1", "duration": 1.0}}, {"id": 315, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 316, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1071_1#1$1", "focus": "l"}}, {"id": 317, "prop": "name", "attributes": {"content": "這場葬禮就到此為止吧，拂哀菈。族人們都已經回庭院了，夜晚要來了。", "name": "菈瑪蓮"}}, {"id": 318, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_2048_1#8$1", "focus": "r"}}, {"id": 319, "prop": "name", "attributes": {"content": "三個月。德莫伊在棲腳樹下的木屋熬過了整整三個月，才等來死亡。", "name": "拂哀菈"}}, {"id": 320, "prop": "name", "attributes": {"content": "能做的，我都做了，但……慢慢變成一具空殼的痛苦，我緩解不了。", "name": "拂哀菈"}}, {"id": 321, "prop": "name", "attributes": {"content": "她向來不是個哀愁的人，湖岸的整片蘆葦都會因她的笑聲而飄蕩起來。", "name": "拂哀菈"}}, {"id": 322, "prop": "name", "attributes": {"content": "但這兩百年來所有稱得上愉快的記憶，在她搬進木屋的最初三天，就消散殆盡，不留一絲痕跡，我想撿，都撿不起。", "name": "拂哀菈"}}, {"id": 323, "prop": "name", "attributes": {"content": "剩下的三個月裡，當其餘的記憶也棄她而去，她就只能從喉嚨裡擠出斷斷續續的嘶聲。", "name": "拂哀菈"}}, {"id": 324, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1071_1#1$1", "focus": "l"}}, {"id": 325, "prop": "name", "attributes": {"content": "至少，在生前的兩百年間，她確實有過許多歡笑。", "name": "菈瑪蓮"}}, {"id": 326, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_2048_1#4$1", "focus": "r"}}, {"id": 327, "prop": "name", "attributes": {"content": "那究竟是為何，她最終還是不得不在痛苦中死去？", "name": "拂哀菈"}}, {"id": 328, "prop": "name", "attributes": {"content": "兩百年來，自我們定居河谷以來……每一位逝去的女妖，都在死前經歷過這樣一場漫長而痛苦的遺忘。", "name": "拂哀菈"}}, {"id": 329, "prop": "name", "attributes": {"content": "簡直像是個殘忍的玩笑。對逝者而言，女妖本是最後銘記他們存在的人。遺忘從不是我們的天性，銘記才是。", "name": "拂哀菈"}}, {"id": 330, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1071_1#1$1", "focus": "l"}}, {"id": 331, "prop": "name", "attributes": {"content": "遺忘確實是這兩百年間的新事，但你總不該為一種我們尚不瞭解的頑疾而自責。", "name": "菈瑪蓮"}}, {"id": 332, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_2048_1#8$1", "focus": "r"}}, {"id": 333, "prop": "name", "attributes": {"content": "頑疾嗎？還是代價？", "name": "拂哀菈"}}, {"id": 334, "prop": "name", "attributes": {"content": "每次，每個人，最先消散的記憶，總是有關河谷生活的那些。", "name": "拂哀菈"}}, {"id": 335, "prop": "name", "attributes": {"content": "簡直好像……我們所創造的生活，從來都只是棉花一樣的填充物，我們用它替代了族人天性使然的生活方式，然而到頭來……", "name": "拂哀菈"}}, {"id": 336, "prop": "name", "attributes": {"content": "當它隨著時間腐朽，被它填滿的人，就只剩下空殼。", "name": "拂哀菈"}}, {"id": 337, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1071_1#7$1", "focus": "l"}}, {"id": 338, "prop": "name", "attributes": {"content": "我們本來要做的，不就是這樣的事嗎？", "name": "菈瑪蓮"}}, {"id": 339, "prop": "name", "attributes": {"content": "為女妖、為薩卡茲，創造一種不同以往的生活——一種與歌聲和糕點，而不是戰爭和死亡相伴的生活。", "name": "菈瑪蓮"}}, {"id": 340, "prop": "name", "attributes": {"content": "殿下也向我們許諾過，記得嗎？我們在河谷經營這一切的同時，她會以魔王的身分，引導族群告別久積的仇怨與殺戮的天性。", "name": "菈瑪蓮"}}, {"id": 341, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_2048_1#8$1", "focus": "r"}}, {"id": 342, "prop": "name", "attributes": {"content": "你親口告訴過我，殿下已經轉而向源石尋求答案了……與那位“勛爵”一同。", "name": "拂哀菈"}}, {"id": 343, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1071_1#2$1", "focus": "l"}}, {"id": 344, "prop": "name", "attributes": {"content": "我後來又與殿下有過幾次交談。她從沒忘記過我們曾經的理想。", "name": "菈瑪蓮"}}, {"id": 345, "prop": "name", "attributes": {"content": "她只是換了一種更決絕的方式去履行諾言。若有朝一日，她的花海能開滿大地……薩卡茲只會更需要一種新的生活。", "name": "菈瑪蓮"}}, {"id": 346, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_2048_1#4$1", "focus": "r"}}, {"id": 347, "prop": "name", "attributes": {"content": "但願河谷還能撐到那個時候。", "name": "拂哀菈"}}, {"id": 348, "prop": "name", "attributes": {"content": "棲腳樹仍在枯萎，它的根系已經開始腐敗。土石之子的巫術、我自己的咒言，都沒能起效。", "name": "拂哀菈"}}, {"id": 349, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1071_1#3$1", "focus": "l"}}, {"id": 350, "prop": "name", "attributes": {"content": "棲腳樹的事，無論如何都會有辦法的。我只願……你還能看見那個未來。", "name": "菈瑪蓮"}}, {"id": 351, "prop": "name", "attributes": {"content": "這三個月以來，你為了陪伴德莫伊，可曾有一個晚上闔過眼？", "name": "菈瑪蓮"}}, {"id": 352, "prop": "name", "attributes": {"content": "她至少能在你咒言的安撫下，聽一聽霧湖的水聲和舟楫聲，獲得片刻的安寧。", "name": "菈瑪蓮"}}, {"id": 353, "prop": "name", "attributes": {"content": "但你自己呢？", "name": "菈瑪蓮"}}, {"id": 354, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_2048_1#7$1", "focus": "r"}}, {"id": 355, "prop": "name", "attributes": {"content": "德莫伊一走，經歷過兩百年前那場戰爭的女妖，也只剩你我了。", "name": "拂哀菈"}}, {"id": 356, "prop": "name", "attributes": {"content": "這些代價，只能由我來承擔。", "name": "拂哀菈"}}, {"id": 357, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1071_1#3$1", "focus": "l"}}, {"id": 358, "prop": "name", "attributes": {"content": "還有孩子們呢，不是嗎？", "name": "菈瑪蓮"}}, {"id": 359, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_2048_1#8$1", "focus": "r"}}, {"id": 360, "prop": "name", "attributes": {"content": "所以，你才把哀琺尼爾送去了卡茲戴爾？", "name": "拂哀菈"}}, {"id": 361, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1071_1#1$1", "focus": "l"}}, {"id": 362, "prop": "name", "attributes": {"content": "女妖的未來，總該交給孩子們的。", "name": "菈瑪蓮"}}, {"id": 363, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_2048_1#8$1", "focus": "r"}}, {"id": 364, "prop": "name", "attributes": {"content": "不論我們的決定是對是錯，都不該讓孩子們去承擔代價。", "name": "拂哀菈"}}, {"id": 365, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1071_1#10$1", "focus": "l"}}, {"id": 366, "prop": "name", "attributes": {"content": "……所以你才沒讓娜斯提參加這場葬禮？", "name": "菈瑪蓮"}}, {"id": 367, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_2048_1#4$1", "focus": "r"}}, {"id": 368, "prop": "name", "attributes": {"content": "幸好我沒讓她來。如果河谷的生活依然只是像填充用的棉花一樣脆弱的存在，那……", "name": "拂哀菈"}}, {"id": 369, "prop": "name", "attributes": {"content": "娜斯提是在卡茲戴爾掙扎著長大的孩子，死亡在她眼裡，就只是滿地冒出來的源石晶簇。", "name": "拂哀菈"}}, {"id": 370, "prop": "name", "attributes": {"content": "面對死亡，她的態度一定會讓其他孩子起疑。", "name": "拂哀菈"}}, {"id": 371, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1071_1#1$1", "focus": "l"}}, {"id": 372, "prop": "name", "attributes": {"content": "她是個聰明的孩子，不會不明白你的意圖。", "name": "菈瑪蓮"}}, {"id": 373, "prop": "name", "attributes": {"content": "當年，她想把自己的樹屋搭在棲腳樹旁邊，但最終，你還是讓她搭在了生長著霧芯果的林地。", "name": "菈瑪蓮"}}, {"id": 374, "prop": "name", "attributes": {"content": "你幾乎不帶她來族人們聚會的庭院，也不允許她系統地學習咒言和輓歌……你是怎麼向她解釋的？", "name": "菈瑪蓮"}}, {"id": 375, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_2048_1#1$1", "focus": "r"}}, {"id": 376, "prop": "name", "attributes": {"content": "孩子們太吵鬧了，我這個“管家”只好住遠一點，好讓耳根清淨。我的忙碌她都看在眼裡……", "name": "拂哀菈"}}, {"id": 377, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1071_1#1$1", "focus": "l"}}, {"id": 378, "prop": "name", "attributes": {"content": "她信了？", "name": "菈瑪蓮"}}, {"id": 379, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_2048_1#1$1", "focus": "r"}}, {"id": 380, "prop": "name", "attributes": {"content": "起碼沒說什麼。", "name": "拂哀菈"}}, {"id": 381, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1071_1#1$1", "focus": "l"}}, {"id": 382, "prop": "name", "attributes": {"content": "……", "name": "菈瑪蓮"}}, {"id": 383, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_2048_1#1$1", "focus": "r"}}, {"id": 384, "prop": "name", "attributes": {"content": "好了，菈瑪蓮，你回去吧。", "name": "拂哀菈"}}, {"id": 385, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1071_1#1$1", "focus": "l"}}, {"id": 386, "prop": "name", "attributes": {"content": "你呢？", "name": "菈瑪蓮"}}, {"id": 387, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_2048_1#1$1", "focus": "r"}}, {"id": 388, "prop": "name", "attributes": {"content": "我想再待一會。", "name": "拂哀菈"}}, {"id": 389, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1071_1#5$1", "focus": "l"}}, {"id": 390, "prop": "name", "attributes": {"content": "這首輓歌，你唱得夠久了。", "name": "菈瑪蓮"}}, {"id": 391, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_2048_1#4$1", "focus": "r"}}, {"id": 392, "prop": "name", "attributes": {"content": "……我只是不知道自己還能做些什麼。河谷在步入腐敗，而河谷之外，那些因我的過錯而無處可歸的魂靈，仍在悲泣。", "name": "拂哀菈"}}, {"id": 393, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1071_1#5$1", "focus": "l"}}, {"id": 394, "prop": "name", "attributes": {"content": "至少，你還可以回去陪陪娜斯提。", "name": "菈瑪蓮"}}, {"id": 395, "prop": "name", "attributes": {"content": "作為母親，我們不一定能承受把孩子關在門外的代價。", "name": "菈瑪蓮"}}, {"id": 396, "prop": "name", "attributes": {"content": "你關上那扇門，只是為了隔絕一些殘忍的真相。但對孩子而言，你是在將她推遠……", "name": "菈瑪蓮"}}, {"id": 397, "prop": "Dialog", "attributes": {}}, {"id": 398, "prop": "playsound", "attributes": {"key": "$d_avg_walkmeadow"}}, {"id": 399, "prop": "charslot", "attributes": {"slot": "l", "posfrom": "0,0", "posto": "-150,0", "duration": 1.0, "afrom": 1.0, "ato": 0.0}}, {"id": 400, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 401, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_2048_1#8$1", "focus": "r"}}, {"id": 402, "prop": "name", "attributes": {"content": "……", "name": "拂哀菈"}}, {"id": 403, "prop": "name", "attributes": {"content": "這幾天，我不是沒有預感過，娜斯提的離去……", "name": "拂哀菈"}}, {"id": 404, "prop": "Dialog", "attributes": {}}, {"id": 405, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 406, "prop": "charslot", "attributes": {}}, {"id": 407, "prop": "Image", "attributes": {"image": "68_i05_2", "screenadapt": "coverall", "fadetime": 0.0}}, {"id": 408, "prop": "curtain", "attributes": {"direction": 0.0, "fillfrom": 0.2, "fillto": 0.2, "fadetime": 0.1}}, {"id": 409, "prop": "curtain", "attributes": {"direction": 4.0, "fillfrom": 0.2, "fillto": 0.2, "fadetime": 0.1}}, {"id": 410, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 411, "prop": "Background", "attributes": {}}, {"id": 412, "prop": "bgeffect", "attributes": {"name": "$eb_068cg_birds", "layer": 1.0}}, {"id": 413, "prop": "Blocker", "attributes": {"a": 0.3, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 414, "prop": "Subtitle", "attributes": {"text": "我只是沒有想到，這一天會來得如此快。", "x": 300.0, "y": 350.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 415, "prop": "subtitle", "attributes": {}}, {"id": 416, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 417, "prop": "bgeffect", "attributes": {}}, {"id": 418, "prop": "name", "attributes": {"content": "確實是個唐突的決定。", "name": "娜斯提"}}, {"id": 419, "prop": "name", "attributes": {"content": "……", "name": "娜斯提"}}, {"id": 420, "prop": "name", "attributes": {"content": "……", "name": "拂哀菈"}}, {"id": 421, "prop": "Dialog", "attributes": {}}, {"id": 422, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 423, "prop": "charslot", "attributes": {}}, {"id": 424, "prop": "curtain", "attributes": {}}, {"id": 425, "prop": "bgeffect", "attributes": {"name": "$eb_cnclouds", "layer": 1.0}}, {"id": 426, "prop": "Image", "attributes": {"image": "68_i05_1", "xScale": 1.2, "yScale": 1.2, "screenadapt": "coverall", "x": 50.0, "fadetime": 0.0}}, {"id": 427, "prop": "playsound", "attributes": {"key": "$d_avg_breezeblow_amb", "loop": "true", "channel": "bgs", "volume": 0.0}}, {"id": 428, "prop": "SoundVolume", "attributes": {"volume": 0.6, "channel": "bgs", "fadetime": 2.0}}, {"id": 429, "prop": "delay", "attributes": {"time": 0.25}}, {"id": 430, "prop": "ImageTween", "attributes": {"duration": 60.0}}, {"id": 431, "prop": "playsound", "attributes": {"key": "$d_avg_boat_lake_loop", "loop": "true", "channel": "sl", "volume": 0.0}}, {"id": 432, "prop": "SoundVolume", "attributes": {"volume": 1.0, "channel": "sl", "fadetime": 2.0}}, {"id": 433, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 434, "prop": "name", "attributes": {"content": "一艘單薄的小船順流而下，年老的女妖用咒言催動著它，向河谷之外駛去。"}}, {"id": 435, "prop": "name", "attributes": {"content": "蘆葦搖盪，薄霧隱去了湖面上的落葉。因為看不出季節，所以無法定義這場離別的底色。"}}, {"id": 436, "prop": "SoundVolume", "attributes": {"volume": 0.2, "channel": "sl", "fadetime": 2.0}}, {"id": 437, "prop": "name", "attributes": {"content": "我本來希望，你可以在河谷中安然度過餘生。", "name": "拂哀菈"}}, {"id": 438, "prop": "name", "attributes": {"content": "沒能更早地找到你，本就是我的過失。你已經為此吃了太多的苦。", "name": "拂哀菈"}}, {"id": 439, "prop": "name", "attributes": {"content": "決定將你帶回河谷時，我便應該為此負責。但最終……", "name": "拂哀菈"}}, {"id": 440, "prop": "name", "attributes": {"content": "請原諒我的矛盾，娜斯提。", "name": "拂哀菈"}}, {"id": 441, "prop": "name", "attributes": {"content": "我離開不是因為你，拂哀菈。", "name": "娜斯提"}}, {"id": 442, "prop": "name", "attributes": {"content": "……起碼不是出於你以為的原因。", "name": "娜斯提"}}, {"id": 443, "prop": "name", "attributes": {"content": "不像那些孩子，你清楚卡茲戴爾如今仍是那般……", "name": "拂哀菈"}}, {"id": 444, "prop": "name", "attributes": {"content": "活人還是在充斥著鐵鏽和糞便味的集市上打架，死人身上的結晶還是像野草一樣從身體裡冒出來……", "name": "娜斯提"}}, {"id": 445, "prop": "name", "attributes": {"content": "那個地方沒有我要的答案。", "name": "娜斯提"}}, {"id": 446, "prop": "name", "attributes": {"content": "但你的問題是什麼呢？", "name": "拂哀菈"}}, {"id": 447, "prop": "name", "attributes": {"content": "……", "name": "娜斯提"}}, {"id": 448, "prop": "name", "attributes": {"content": "那、那你打算去哪裡？", "name": "拂哀菈"}}, {"id": 449, "prop": "name", "attributes": {"content": "我不知道。或許，我會用從你那裡偷學來的半吊子咒言，在谷口丟幾塊石頭，讓它們為我決定一個方向。", "name": "娜斯提"}}, {"id": 450, "prop": "name", "attributes": {"content": "萊塔尼亞？拉特蘭？哥倫比亞？", "name": "娜斯提"}}, {"id": 451, "prop": "name", "attributes": {"content": "還在卡茲戴爾流浪的時候，我聽說過這些陌生的名字。", "name": "娜斯提"}}, {"id": 452, "prop": "name", "attributes": {"content": "那些地方啊……", "name": "拂哀菈"}}, {"id": 453, "prop": "name", "attributes": {"content": "那些地方好遙遠……", "name": "拂哀菈"}}, {"id": 454, "prop": "Dialog", "attributes": {}}, {"id": 455, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 456, "prop": "name", "attributes": {"content": "怎麼了？", "name": "娜斯提"}}, {"id": 457, "prop": "name", "attributes": {"content": "……", "name": "拂哀菈"}}, {"id": 458, "prop": "name", "attributes": {"content": "注意安全，好好吃飯，孩子。", "name": "拂哀菈"}}, {"id": 459, "prop": "name", "attributes": {"content": "沉默良久，拂哀菈只說出了這麼一句話。"}}, {"id": 460, "prop": "name", "attributes": {"content": "年老的女妖在為人報喪的途中行走過千萬里路，但她突然意識到，那些地名對她而言同樣陌生。"}}, {"id": 461, "prop": "name", "attributes": {"content": "遠行的養女即將開啟一段旅程，但她卻無從想像旅程的終點是什麼景象，更不知道該叮囑些什麼。"}}, {"id": 462, "prop": "name", "attributes": {"content": "行船的水聲悠悠，娜斯提沒有回頭。"}}, {"id": 463, "prop": "name", "attributes": {"content": "再見……母親。", "name": "娜斯提"}}, {"id": 464, "prop": "Dialog", "attributes": {}}, {"id": 465, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "fadetime": 2.0, "keep": "true", "initamount": 0.0, "amount": 1.0, "block": "true"}}, {"id": 466, "prop": "StopSound", "attributes": {"channel": "sl", "fadetime": 2.0}}, {"id": 467, "prop": "StopSound", "attributes": {"channel": "bgs", "fadetime": 2.0}}, {"id": 468, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 469, "prop": "bgeffect", "attributes": {}}, {"id": 470, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "fadetime": 0.0, "amount": 0.0, "block": "true"}}, {"id": 471, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 472, "prop": "hidecgitem", "attributes": {}}, {"id": 473, "prop": "Image", "attributes": {}}, {"id": 474, "prop": "charslot", "attributes": {}}, {"id": 475, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}