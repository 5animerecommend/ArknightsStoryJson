ot": "l", "name": "avg_npc_901_1#1$1", "isblock": "true"}}, {"id": 270, "prop": "charslot", "attributes": {"slot": "l", "focus": "l"}}, {"id": 271, "prop": "name", "attributes": {"content": "呃……", "name": "園區警衛A"}, "figure_art": "avg_npc_901_1#1$1"}, {"id": 272, "prop": "charslot", "attributes": {"slot": "r", "focus": "r"}}, {"id": 273, "prop": "name", "attributes": {"content": "各位放心，我們只是受高登長官指示，模擬未來在影月上執行任務的情況。", "name": "園區警衛B"}, "figure_art": "avg_npc_901_1#1$1"}, {"id": 274, "prop": "charslot", "attributes": {"slot": "r", "focus": "r"}}, {"id": 275, "prop": "name", "attributes": {"content": "無論身處何方，哥倫比亞都會無條件保障公民的安全。", "name": "園區警衛B"}, "figure_art": "avg_npc_901_1#1$1"}, {"id": 276, "prop": "charslot", "attributes": {"slot": "r", "focus": "r"}}, {"id": 277, "prop": "name", "attributes": {"content": "（分頭找，記得低調行事。）", "name": "園區警衛B"}, "figure_art": "avg_npc_901_1#1$1"}, {"id": 278, "prop": "charslot", "attributes": {"slot": "l", "focus": "l"}}, {"id": 279, "prop": "name", "attributes": {"content": "（是。）", "name": "園區警衛A"}, "figure_art": "avg_npc_901_1#1$1"}, {"id": 280, "prop": "dialog", "attributes": {}}, {"id": 281, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 282, "prop": "charslot", "attributes": {"slot": "r", "afrom": 1.0, "ato": 0.0, "duration": 1.5, "isblock": "false"}}, {"id": 283, "prop": "charslot", "attributes": {"slot": "l", "afrom": 1.0, "ato": 0.0, "duration": 1.5, "isblock": "true"}}, {"id": 284, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 285, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 286, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2044_1#1$1", "posfrom": "-200,0", "charslot": "0,0", "duration": 1.2, "isblock": "true"}}, {"id": 287, "prop": "name", "attributes": {"content": "原來真的是模擬演習……跟藍卡塢大片《影月爭霸》裡的橋段一模一樣！", "name": "體驗員"}, "figure_art": "avg_npc_2044_1#1$1"}, {"id": 288, "prop": "dialog", "attributes": {}}, {"id": 289, "prop": "charslot", "attributes": {}}, {"id": 290, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1000_1#1$1", "duration": 0.5}}, {"id": 291, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4214_cairn_1#1$1", "duration": 0.5, "isblock": "true"}}, {"id": 292, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4214_cairn_1#1$1", "focus": "l"}}, {"id": 293, "prop": "name", "attributes": {"content": "我們沒騙你吧？那些警衛就是卡西米爾太空騎士，你一定要好好掩護我們哦！", "name": "費爾南"}, "figure_art": "avg_4214_cairn_1#1$1"}, {"id": 294, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1000_1#1$1", "focus": "r"}}, {"id": 295, "prop": "name", "attributes": {"content": "別打哈哈了，冒牌貨。接下來我們應該往哪裡跑？", "name": "奧克里"}, "figure_art": "avg_npc_1000_1#1$1"}, {"id": 296, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4214_cairn_1#7$1", "focus": "l"}}, {"id": 297, "prop": "name", "attributes": {"content": "飛天甜甜圈站的藏身之處不多，後面的環形廊道又容易被埋伏……", "name": "費爾南"}, "figure_art": "avg_4214_cairn_1#7$1"}, {"id": 298, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1000_1#2$1", "focus": "r"}}, {"id": 299, "prop": "name", "attributes": {"content": "那我們難道出去送死？我們兩個是簽了旅行社合約的，你必須把我帶出去！", "name": "奧克里"}, "figure_art": "avg_npc_1000_1#2$1"}, {"id": 300, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4214_cairn_1#3$1", "focus": "l"}}, {"id": 301, "prop": "name", "attributes": {"content": "別著急，正牌貨。這裡可是“螺旋槳天堂”啊，忘掉地面上的邏輯。", "name": "費爾南"}, "figure_art": "avg_4214_cairn_1#3$1"}, {"id": 302, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4214_cairn_1#3$1", "focus": "l"}}, {"id": 303, "prop": "name", "attributes": {"content": "先生，你正在測試的是沃爾沃特科欽斯基的滯空跳板對吧？可以借我們用一下嗎？", "name": "費爾南"}, "figure_art": "avg_4214_cairn_1#3$1"}, {"id": 304, "prop": "dialog", "attributes": {}}, {"id": 305, "prop": "charslot", "attributes": {}}, {"id": 306, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2044_1#1$1", "isblock": "true"}}, {"id": 307, "prop": "name", "attributes": {"content": "沒問題。", "name": "體驗員"}, "figure_art": "avg_npc_2044_1#1$1"}, {"id": 308, "prop": "dialog", "attributes": {}}, {"id": 309, "prop": "charslot", "attributes": {}}, {"id": 310, "prop": "PlaySound", "attributes": {"key": "$d_avg_hgldshcrrig", "volume": 1.0}}, {"id": 311, "prop": "PlaySound", "attributes": {"key": "$d_avg_crrigrunwght", "volume": 1.0}}, {"id": 312, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 313, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_901_1#1$1"}}, {"id": 314, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_901_1#1$1", "isblock": "true"}}, {"id": 315, "prop": "charslot", "attributes": {"slot": "l", "focus": "l"}}, {"id": 316, "prop": "name", "attributes": {"content": "嗯？什麼聲音？", "name": "園區警衛A"}, "figure_art": "avg_npc_901_1#1$1"}, {"id": 317, "prop": "charslot", "attributes": {"slot": "r", "focus": "r"}}, {"id": 318, "prop": "name", "attributes": {"content": "快抬頭！", "name": "園區警衛B"}, "figure_art": "avg_npc_901_1#1$1"}, {"id": 319, "prop": "charslot", "attributes": {"slot": "l", "focus": "l"}}, {"id": 320, "prop": "name", "attributes": {"content": "天啊，他們怎麼跑到浮空艙頂上了？！", "name": "園區警衛A"}, "figure_art": "avg_npc_901_1#1$1"}, {"id": 321, "prop": "dialog", "attributes": {}}, {"id": 322, "prop": "charslot", "attributes": {}}, {"id": 323, "prop": "name", "attributes": {"content": "哈哈，我怎麼忘了，在“螺旋槳天堂”，所有人都是會抬頭看的。", "name": "費爾南"}}, {"id": 324, "prop": "name", "attributes": {"content": "那現在怎麼辦！", "name": "奧克里"}}, {"id": 325, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_901_1#1$1"}}, {"id": 326, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_901_1#1$1", "isblock": "true"}}, {"id": 327, "prop": "charslot", "attributes": {"slot": "l", "focus": "l"}}, {"id": 328, "prop": "name", "attributes": {"content": "把他們給我炸下來！", "name": "園區警衛A"}, "figure_art": "avg_npc_901_1#1$1"}, {"id": 329, "prop": "dialog", "attributes": {}}, {"id": 330, "prop": "charslot", "attributes": {}}, {"id": 331, "prop": "PlaySound", "attributes": {"key": "$d_avg_cannon", "volume": 1.0}}, {"id": 332, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 333, "prop": "Blocker", "attributes": {"a": 0.8, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 0.3, "block": "true"}}, {"id": 334, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.1, "block": "true"}}, {"id": 335, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 336, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2044_1#1$1", "isblock": "true"}}, {"id": 337, "prop": "name", "attributes": {"content": "哦——這是在模擬電影最精彩的那一段中反派使用的空氣炮嗎？", "name": "體驗員"}, "figure_art": "avg_npc_2044_1#1$1"}, {"id": 338, "prop": "name", "attributes": {"content": "等等，這是源石火藥的味道……", "name": "體驗員"}, "figure_art": "avg_npc_2044_1#1$1"}, {"id": 339, "prop": "dialog", "attributes": {}}, {"id": 340, "prop": "charslot", "attributes": {}}, {"id": 341, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_901_1#1$1", "isblock": "true"}}, {"id": 342, "prop": "name", "attributes": {"content": "開火！", "name": "園區警衛A"}, "figure_art": "avg_npc_901_1#1$1"}, {"id": 343, "prop": "dialog", "attributes": {}}, {"id": 344, "prop": "charslot", "attributes": {}}, {"id": 345, "prop": "PlaySound", "attributes": {"key": "$d_avg_cannon", "volume": 1.0}}, {"id": 346, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 347, "prop": "Blocker", "attributes": {"a": 0.8, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 0.3, "block": "true"}}, {"id": 348, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.1, "block": "true"}}, {"id": 349, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 350, "prop": "PlaySound", "attributes": {"key": "$d_avg_crrigrunlght", "volume": 1.0}}, {"id": 351, "prop": "name", "attributes": {"content": "跑啊！", "name": "費爾南"}}, {"id": 352, "prop": "Dialog", "attributes": {}}, {"id": 353, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 354, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 355, "prop": "charslot", "attributes": {}}, {"id": 356, "prop": "Background", "attributes": {"image": "68_g8_gordoncollection", "screenadapt": "coverall"}}, {"id": 357, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 358, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 359, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 360, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2034_1#7$1", "isblock": "true"}}, {"id": 361, "prop": "name", "attributes": {"content": "一個兩個都是廢物！好不容易控制住萊茵，又跑了一個不安分的導遊……", "name": "高登"}, "figure_art": "avg_npc_2034_1#7$1"}, {"id": 362, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2034_1#7$1", "isblock": "true"}}, {"id": 363, "prop": "name", "attributes": {"content": "要不是接下來還有生意要做，我一定親自去把那個菲林逮回來。", "name": "高登"}, "figure_art": "avg_npc_2034_1#7$1"}, {"id": 364, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2040_1#1$1", "isblock": "true"}}, {"id": 365, "prop": "name", "attributes": {"content": "“天空征服者”，要不要我替你解決那些愚昧的泰拉人，讓他們見識一下來自外泰拉的絕對力量。", "name": "太空鱗獸"}, "figure_art": "avg_npc_2040_1#1$1"}, {"id": 366, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2034_1#8$1", "isblock": "true"}}, {"id": 367, "prop": "name", "attributes": {"content": "暫時不用，零五四。一個導遊而已，又不是特工。", "name": "高登"}, "figure_art": "avg_npc_2034_1#8$1"}, {"id": 368, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2034_1#1$1", "isblock": "true"}}, {"id": 369, "prop": "name", "attributes": {"content": "先彙報古斯塔夫的情況。", "name": "高登"}, "figure_art": "avg_npc_2034_1#1$1"}, {"id": 370, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2040_1#1$3", "isblock": "true"}}, {"id": 371, "prop": "name", "attributes": {"content": "他跟隨從一直駐守在雲中餐廳和貴賓接待區，環形廊道是必經之路，但暫時沒人發現暗門。", "name": "太空鱗獸"}, "figure_art": "avg_npc_2040_1#1$3"}, {"id": 372, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2034_1#9$1", "isblock": "true"}}, {"id": 373, "prop": "name", "attributes": {"content": "呵，七年前我剛進管理局工作的時候，就算只是從偷渡客口袋裡摸走一個液化源石打火機，都會被古斯塔夫發現。", "name": "高登"}, "figure_art": "avg_npc_2034_1#9$1"}, {"id": 374, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2034_1#1$1", "isblock": "true"}}, {"id": 375, "prop": "name", "attributes": {"content": "他是軍人出身，我以為他是過於正直所以故意針對我，後來我才知道，古斯塔夫是嫌我做事不夠乾淨。", "name": "高登"}, "figure_art": "avg_npc_2034_1#1$1"}, {"id": 376, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2034_1#3$1", "isblock": "true"}}, {"id": 377, "prop": "name", "attributes": {"content": "他的手段、話術，甚至這身西裝我都學來了。至於成果——", "name": "高登"}, "figure_art": "avg_npc_2034_1#3$1"}, {"id": 378, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2040_1#1$2", "isblock": "true"}}, {"id": 379, "prop": "name", "attributes": {"content": "這是一間存放泰拉各地奇珍異寶的“船艙”。", "name": "太空鱗獸"}, "figure_art": "avg_npc_2040_1#1$2"}, {"id": 380, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2034_1#1$1", "isblock": "true"}}, {"id": 381, "prop": "name", "attributes": {"content": "比管理局骯髒的儲物櫃大了不少。", "name": "高登"}, "figure_art": "avg_npc_2034_1#1$1"}, {"id": 382, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2034_1#1$1", "isblock": "true"}}, {"id": 383, "prop": "name", "attributes": {"content": "一邊是古斯塔夫，一邊是娜斯提，那又如何？", "name": "高登"}, "figure_art": "avg_npc_2034_1#1$1"}, {"id": 384, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2034_1#9$1", "isblock": "true"}}, {"id": 385, "prop": "name", "attributes": {"content": "我已經不是七年前的毛頭小子了。除非我把罪證送到他們面前，不然他們這輩子都不可能發現我的手段。", "name": "高登"}, "figure_art": "avg_npc_2034_1#9$1"}, {"id": 386, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2034_1#8$1", "isblock": "true"}}, {"id": 387, "prop": "name", "attributes": {"content": "等到展覽開始，上萬件展品飛向天空，“秘密”、“違規交易”……一切都不重要了。", "name": "高登"}, "figure_art": "avg_npc_2034_1#8$1"}, {"id": 388, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2034_1#2$1", "isblock": "true"}}, {"id": 389, "prop": "name", "attributes": {"content": "到時候所有人都會知道——不是萊茵，也不是特區政府，而是高登·譚農為“螺旋槳天堂”點了一把火。", "name": "高登"}, "figure_art": "avg_npc_2034_1#2$1"}, {"id": 390, "prop": "dialog", "attributes": {}}, {"id": 391, "prop": "charslot", "attributes": {}}, {"id": 392, "prop": "PlaySound", "attributes": {"key": "$d_avg_crrigrunlght", "volume": 1.0}}, {"id": 393, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 394, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2040_1#1$5", "isblock": "true"}}, {"id": 395, "prop": "name", "attributes": {"content": "注意！監測到泰拉人正在靠近！", "name": "太空鱗獸"}, "figure_art": "avg_npc_2040_1#1$5"}, {"id": 396, "prop": "dialog", "attributes": {}}, {"id": 397, "prop": "charslot", "attributes": {}}, {"id": 398, "prop": "PlaySound", "attributes": {"key": "$d_avg_autocannon", "volume": 1.0}}, {"id": 399, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 400, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2034_1#1$1", "isblock": "true"}}, {"id": 401, "prop": "name", "attributes": {"content": "什麼聲音？", "name": "高登"}, "figure_art": "avg_npc_2034_1#1$1"}, {"id": 402, "prop": "dialog", "attributes": {}}, {"id": 403, "prop": "charslot", "attributes": {}}, {"id": 404, "prop": "name", "attributes": {"content": "別炸……底下……萬一有人……", "name": "？？？"}}, {"id": 405, "prop": "name", "attributes": {"content": "……花言巧語……！", "name": "？？"}}, {"id": 406, "prop": "name", "attributes": {"content": "啊……！", "name": "？？？"}}, {"id": 407, "prop": "dialog", "attributes": {}}, {"id": 408, "prop": "PlaySound", "attributes": {"key": "$d_avg_cannon", "volume": 1.0}}, {"id": 409, "prop": "CameraShake", "attributes": {"duration": 8.0, "xstrength": 10.0, "ystrength": 10.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 410, "prop": "Blocker", "attributes": {"a": 1.0, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 0.5, "block": "true"}}, {"id": 411, "prop": "PlaySound", "attributes": {"key": "$glass", "volume": 1.0}}, {"id": 412, "prop": "PlaySound", "attributes": {"key": "$smallearthquake", "volume": 1.0}}, {"id": 413, "prop": "Image", "attributes": {"image": "68_i03", "screenadapt": "coverall", "fadetime": 0.0}}, {"id": 414, "prop": "name", "attributes": {"content": "一片煙霧之中，高登抬起頭，用力睜開流淚的眼睛，試圖看清到底發生了什麼。"}}, {"id": 415, "prop": "dialog", "attributes": {}}, {"id": 416, "prop": "curtain", "attributes": {"direction": 0.0, "fillfrom": 0.01, "fillto": 0.1, "fadetime": 0.1, "block": "false"}}, {"id": 417, "prop": "curtain", "attributes": {"direction": 4.0, "fillfrom": 0.5, "fillto": 0.5, "fadetime": 0.1, "block": "false"}}, {"id": 418, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "false"}}, {"id": 419, "prop": "ImageTween", "attributes": {"image": "68_i03", "xScaleFrom": 1.0, "yScaleFrom": 1.0, "xScaleTo": 1.5, "yScaleTo": 1.5, "xFrom": 0.0, "yFrom": 0.0, "duration": 0.3, "block": "true"}}, {"id": 420, "prop": "delay", "attributes": {"time": 0.7}}, {"id": 421, "prop": "ImageTween", "attributes": {"image": "68_i03", "xScaleFrom": 1.5, "yScaleFrom": 1.5, "xScaleTo": 1.4, "yScaleTo": 1.4, "duration": 10.0, "block": "false"}}, {"id": 422, "prop": "PlaySound", "attributes": {"key": "$d_avg_timestop", "volume": 1.0}}, {"id": 423, "prop": "name", "attributes": {"content": "一個熟悉的人影從碎石和粉塵之中落下，四肢不受控制地揮動——幾個小時前才被高登下令通緝的對象，竟然憑空出現在他面前。"}}, {"id": 424, "prop": "name", "attributes": {"content": "此刻，他們的距離只有九十公分，無數思緒從兩人高速運轉的大腦中滑過。"}}, {"id": 425, "prop": "name", "attributes": {"content": "一切似乎都靜止了，高登和費爾南慌亂地捕捉對方的表情和眼神，各懷鬼胎，隔空對望。"}}, {"id": 426, "prop": "name", "attributes": {"content": "（那群警衛真的說炸就炸啊！不對，這是哪裡？為什麼我的地圖裡沒有標記這個地方？環形廊道還有暗門？）", "name": "費爾南"}}, {"id": 427, "prop": "name", "attributes": {"content": "（高登長官？怎麼撞他銃口上了！這是他的圈套？但他為什麼一臉驚訝地看著我，表情還那麼僵硬？）", "name": "費爾南"}}, {"id": 428, "prop": "name", "attributes": {"content": "（牆上的東西，是展品？）", "name": "費爾南"}}, {"id": 429, "prop": "name", "attributes": {"content": "（不對！我當初被薩卡茲抓進黑市時，絕對在地攤上見過這種施術裝置；還有那邊的帽子，那不是薩爾貢墓室裡長生軍的基本配件嗎……）", "name": "費爾南"}}, {"id": 430, "prop": "name", "attributes": {"content": "（嘶……我可能撞進不得了的地方了。現在裝作沒看見，還來得及嗎……）", "name": "費爾南"}}, {"id": 431, "prop": "dialog", "attributes": {}}, {"id": 432, "prop": "curtain", "attributes": {"direction": 0.0, "fillfrom": 0.1, "fillto": 0.2, "fadetime": 0.4, "block": "false"}}, {"id": 433, "prop": "curtain", "attributes": {"direction": 4.0, "fillfrom": 0.5, "fillto": 0.3, "fadetime": 0.4, "block": "true"}}, {"id": 434, "prop": "ImageTween", "attributes": {"image": "68_i03", "xScaleFrom": 1.4, "yScaleFrom": 1.4, "xScaleTo": 1.3, "yScaleTo": 1.3, "xTo": 90.0, "yTo": 20.0, "duration": 15.0, "block": "false"}}, {"id": 435, "prop": "name", "attributes": {"content": "（千萬別撞到高能源石化合手榴彈，不然整個浮空艙都會完蛋的！）", "name": "高登"}}, {"id": 436, "prop": "name", "attributes": {"content": "（他媽的，自從這個冒牌解說員闖進園區以來就沒有一件好事！）", "name": "高登"}}, {"id": 437, "prop": "name", "attributes": {"content": "（她到底是萊茵的仇人，還是娜斯提派來的間諜？每次都破壞我的計劃，生態園是一次，現在又是一次。）", "name": "高登"}}, {"id": 438, "prop": "name", "attributes": {"content": "（她在看什麼？活性源石風暴的引導信標，還是長生軍的巫術頭盔？*哥倫比亞粗口*，她認出來了！）", "name": "高登"}}, {"id": 439, "prop": "name", "attributes": {"content": "（讓這麼一個人抓住我的把柄，說不定她會用這個消息去跟誰交易，要是娜斯提或者古斯塔夫知道了……）", "name": "高登"}}, {"id": 440, "prop": "dialog", "attributes": {}}, {"id": 441, "prop": "Dialog", "attributes": {}}, {"id": 442, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 443, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 444, "prop": "curtain", "attributes": {}}, {"id": 445, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 446, "prop": "Image", "attributes": {"image": "68_i03", "screenadapt": "coverall"}}, {"id": 447, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 448, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 449, "prop": "name", "attributes": {"content": "遲來的重力讓費爾南迅速下墜，高登根本來不及搶救任何藏品，只能眼睜睜看著眼前的菲林女孩朝自己砸來。"}}, {"id": 450, "prop": "name", "attributes": {"content": "兩人的距離急速拉近，腦海裡閃過的複雜念頭全都消失，在撞擊到來之前，兩人只來得及說出一句話——"}}, {"id": 451, "prop": "dialog", "attributes": {}}, {"id": 452, "prop": "Blocker", "attributes": {"a": 1.0, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 1.0, "block": "true"}}, {"id": 453, "prop": "name", "attributes": {"content": "完了……", "name": "高登&費爾南"}}, {"id": 454, "prop": "dialog", "attributes": {}}, {"id": 455, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 2.0, "block": "false"}}, {"id": 456, "prop": "PlaySound", "attributes": {"key": "$d_avg_land_impact", "volume": 1.0, "block": "true"}}, {"id": 457, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 458, "prop": "charslot", "attributes": {}}, {"id": 459, "prop": "image", "attributes": {}}, {"id": 460, "prop": "Background", "attributes": {}}, {"id": 461, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 2.0, "block": "true"}}, {"id": 462, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 463, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 464, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 465, "prop": "charslot", "attributes": {}}, {"id": 466, "prop": "Background", "attributes": {}}, {"id": 467, "prop": "Image", "attributes": {}}, {"id": 468, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}