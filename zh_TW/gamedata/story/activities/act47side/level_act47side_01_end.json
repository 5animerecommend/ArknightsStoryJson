ributes": {"slot": "r", "name": "avg_npc_891_1#1$1", "bstart": 0.2, "bend": 0.7, "duration": 0.8, "isblock": "true"}}, {"id": 118, "prop": "charslot", "attributes": {"slot": "l", "focus": "l"}}, {"id": 119, "prop": "name", "attributes": {"content": "你就不擔心總轄？", "name": "？？？？"}, "figure_art": "avg_npc_892_1#1$1"}, {"id": 120, "prop": "charslot", "attributes": {"slot": "r", "focus": "r"}}, {"id": 121, "prop": "name", "attributes": {"content": "她什麼時候需要我們擔心。", "name": "？？？"}, "figure_art": "avg_npc_891_1#1$1"}, {"id": 122, "prop": "name", "attributes": {"content": "我們是同行者，我們只是同行者。", "name": "？？？"}, "figure_art": "avg_npc_891_1#1$1"}, {"id": 123, "prop": "name", "attributes": {"content": "我們只需要做好自己的事，然後……祝她好運。", "name": "？？？"}, "figure_art": "avg_npc_891_1#1$1"}, {"id": 124, "prop": "name", "attributes": {"content": "（薩卡茲語）若有一天，卡茲戴爾亦懸於天頂，我將在火爐上鐫刻你的名字。", "name": "？？？"}, "figure_art": "avg_npc_891_1#1$1"}, {"id": 125, "prop": "dialog", "attributes": {}}, {"id": 126, "prop": "charslot", "attributes": {}}, {"id": 127, "prop": "PlaySound", "attributes": {"key": "$rungeneral"}}, {"id": 128, "prop": "CameraShake", "attributes": {"duration": 1.2, "xstrength": 10.0, "ystrength": 10.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 129, "prop": "delay", "attributes": {"time": 1.2}}, {"id": 130, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2039_1#5$2", "duration": 1.0, "isblock": "true"}}, {"id": 131, "prop": "name", "attributes": {"content": "呼……呼……", "name": "斯凱"}, "figure_art": "avg_npc_2039_1#5$2"}, {"id": 132, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2039_1#5$2"}}, {"id": 133, "prop": "name", "attributes": {"content": "不、不好意思，女士……", "name": "斯凱"}, "figure_art": "avg_npc_2039_1#5$2"}, {"id": 134, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2039_1#3$2"}}, {"id": 135, "prop": "name", "attributes": {"content": "能不能告訴我，那個人，天上的那個偉大的人……", "name": "斯凱"}, "figure_art": "avg_npc_2039_1#3$2"}, {"id": 136, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2039_1#12$2"}}, {"id": 137, "prop": "name", "attributes": {"content": "叫什麼名字？", "name": "斯凱"}, "figure_art": "avg_npc_2039_1#12$2"}, {"id": 138, "prop": "dialog", "attributes": {}}, {"id": 139, "prop": "charslot", "attributes": {}}, {"id": 140, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_891_1#1$1", "posfrom": "200,0", "posto": "200,0", "bstart": 0.2, "bend": 0.7, "isblock": "true"}}, {"id": 141, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_891_1#1$1", "posfrom": "-200,0", "posto": "-200,0", "duration": 1.2, "isblock": "true"}}, {"id": 142, "prop": "name", "attributes": {"content": "克麗斯騰。", "name": "娜斯提"}, "figure_art": "avg_npc_891_1#1$1"}, {"id": 143, "prop": "name", "attributes": {"content": "她叫克麗斯騰·萊特。", "name": "娜斯提"}, "figure_art": "avg_npc_891_1#1$1"}, {"id": 144, "prop": "dialog", "attributes": {}}, {"id": 145, "prop": "charslot", "attributes": {}}, {"id": 146, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "fadetime": 3.0, "keep": "true", "initamount": 0.0, "amount": 1.0, "block": "true"}}, {"id": 147, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 148, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 149, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 150, "prop": "charslot", "attributes": {}}, {"id": 151, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "fadetime": 0.0, "keep": "true", "initamount": 1.0, "amount": 0.0, "block": "false"}}, {"id": 152, "prop": "Background", "attributes": {"image": "38_g10_ecolab", "screenadapt": "coverall"}}, {"id": 153, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 154, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4212_nasti_1#1$1", "posfrom": "10,0", "posto": "10,0"}}, {"id": 155, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2039_1#7$1", "posfrom": "-10,0", "posto": "-10,0"}}, {"id": 156, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 157, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 158, "prop": "playMusic", "attributes": {"key": "$darkness_03_loop", "volume": 0.6}}, {"id": 159, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 160, "prop": "name", "attributes": {"content": "娜斯提主任，幸運瘤獸餐飲公司明天就會去註銷進駐資格。", "name": "斯凱"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 161, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#1$1"}}, {"id": 162, "prop": "name", "attributes": {"content": "他們沒通過複檢？", "name": "娜斯提"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 163, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#3$1"}}, {"id": 164, "prop": "name", "attributes": {"content": "遠沒有達到標準。他們是最早進駐園區的轉型企業之一，為了迎合民眾的“天空熱”，當時的審核條件不夠嚴格——", "name": "斯凱"}, "figure_art": "avg_npc_2039_1#3$1"}, {"id": 165, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#5$1"}}, {"id": 166, "prop": "name", "attributes": {"content": "他們僱傭的體驗員呢？會去哪裡？", "name": "娜斯提"}, "figure_art": "avg_4212_nasti_1#5$1"}, {"id": 167, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#8$1"}}, {"id": 168, "prop": "name", "attributes": {"content": "那個經理連電機的種類都分不清楚，我猜他只是想藉著“螺旋槳天堂”的名號大撈一筆……", "name": "斯凱"}, "figure_art": "avg_npc_2039_1#8$1"}, {"id": 169, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#5$1"}}, {"id": 170, "prop": "name", "attributes": {"content": "嗯？你剛剛問我什麼？", "name": "斯凱"}, "figure_art": "avg_npc_2039_1#5$1"}, {"id": 171, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#4$1"}}, {"id": 172, "prop": "name", "attributes": {"content": "沒什麼。你倒是很喜歡這個園區的名字。", "name": "娜斯提"}, "figure_art": "avg_4212_nasti_1#4$1"}, {"id": 173, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 174, "prop": "name", "attributes": {"content": "我更希望它能被直接稱作“萬星園”。", "name": "斯凱"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 175, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#1$1"}}, {"id": 176, "prop": "name", "attributes": {"content": "斯凱，我知道你不贊成公開環形實驗室的技術遺產。", "name": "娜斯提"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 177, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 178, "prop": "name", "attributes": {"content": "我無意指責“總轄代理”的決定，但過分保守的決策只會讓我們失去應得的尊重。", "name": "斯凱"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 179, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#3$1"}}, {"id": 180, "prop": "name", "attributes": {"content": "少數的研究資料公開就讓大批科技公司煥發新生；照亮千萬哥倫比亞民眾的環形實驗室，被做成五歲小孩就能玩的益智玩具……", "name": "斯凱"}, "figure_art": "avg_npc_2039_1#3$1"}, {"id": 181, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 182, "prop": "name", "attributes": {"content": "現在，每個哥倫比亞人都會把“太空”和“宇宙”掛在嘴邊，卻很少有人記得，這些全新的語彙出自克麗斯騰公開的實驗日誌。", "name": "斯凱"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 183, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 184, "prop": "name", "attributes": {"content": "沒有一個人在真正地悼念克麗斯騰，甚至是你，娜斯提主任。", "name": "斯凱"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 185, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#1$1"}}, {"id": 186, "prop": "name", "attributes": {"content": "記錄和回顧是史學家的工作。我們只需要分析經過驗證的數據，遵循切實有效的方向。", "name": "娜斯提"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 187, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 188, "prop": "name", "attributes": {"content": "但這些數據和方向變成了什麼呢？", "name": "斯凱"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 189, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 190, "prop": "name", "attributes": {"content": "近兩年萊茵收購了十幾個小型實驗室，大大小小的計劃都在持續進行中，唯獨克麗斯騰的遺產被擱置了。", "name": "斯凱"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 191, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#3$1"}}, {"id": 192, "prop": "name", "attributes": {"content": "這次展覽上，我們將首次公布萊茵對萬星園的後續研究成果，讓不入流的科技公司心服口服，回到天空探索的領域，回到公眾視野。", "name": "斯凱"}, "figure_art": "avg_npc_2039_1#3$1"}, {"id": 193, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#3$1"}}, {"id": 194, "prop": "name", "attributes": {"content": "我知道生態園建立在環形實驗室回傳數據的基礎上，也知道用植物傳輸能量、搭建供能系統在工程設計上是一大壯舉。", "name": "斯凱"}, "figure_art": "avg_npc_2039_1#3$1"}, {"id": 195, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#8$1"}}, {"id": 196, "prop": "name", "attributes": {"content": "培育幼苗、鋪設種植單元、工程檢修，都是為了精進我們的實驗……但一座在預展上都沒機會露面的“植物園”真的足夠嗎？", "name": "斯凱"}, "figure_art": "avg_npc_2039_1#8$1"}, {"id": 197, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#8$1"}}, {"id": 198, "prop": "name", "attributes": {"content": "……", "name": "娜斯提"}, "figure_art": "avg_4212_nasti_1#8$1"}, {"id": 199, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 200, "prop": "name", "attributes": {"content": "懇請你告訴我，娜斯提主任。正如那個夜晚之前，沒人知道克麗斯騰即將突破天幕，萊茵在這裡還有更大的目標，對嗎？", "name": "斯凱"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 201, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#1$1"}}, {"id": 202, "prop": "name", "attributes": {"content": "特里蒙的夜晚已經過去很久了。", "name": "娜斯提"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 203, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 204, "prop": "name", "attributes": {"content": "……", "name": "斯凱"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 205, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#1$1"}}, {"id": 206, "prop": "name", "attributes": {"content": "去準備下一家企業的檢修吧。注意名單順序，出現了一些調整。", "name": "娜斯提"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 207, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 208, "prop": "name", "attributes": {"content": "是。", "name": "斯凱"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 209, "prop": "dialog", "attributes": {}}, {"id": 210, "prop": "charslot", "attributes": {"slot": "l", "posfrom": "-10,0", "posto": "-30,0", "duration": 0.8, "isblock": "false"}}, {"id": 211, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 212, "prop": "charslot", "attributes": {"slot": "r", "focus": "r"}}, {"id": 213, "prop": "name", "attributes": {"content": "斯凱。", "name": "娜斯提"}}, {"id": 214, "prop": "dialog", "attributes": {}}, {"id": 215, "prop": "delay", "attributes": {"time": 0.3}}, {"id": 216, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 217, "prop": "name", "attributes": {"content": "……", "name": "斯凱"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 218, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#4$1"}}, {"id": 219, "prop": "name", "attributes": {"content": "我理解你的心情，也知道你是受到克麗斯騰的鼓舞才選擇加入萊茵。", "name": "娜斯提"}, "figure_art": "avg_4212_nasti_1#4$1"}, {"id": 220, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#8$1"}}, {"id": 221, "prop": "name", "attributes": {"content": "那天晚上有很多人抬頭看向天空，但不是所有人都會去追逐它。", "name": "娜斯提"}, "figure_art": "avg_4212_nasti_1#8$1"}, {"id": 222, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#4$1"}}, {"id": 223, "prop": "name", "attributes": {"content": "別忘了讓你邁出第一步的原因。", "name": "娜斯提"}, "figure_art": "avg_4212_nasti_1#4$1"}, {"id": 224, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#3$1"}}, {"id": 225, "prop": "name", "attributes": {"content": "……我先去準備檢修資料了，主任。", "name": "斯凱"}, "figure_art": "avg_npc_2039_1#3$1"}, {"id": 226, "prop": "dialog", "attributes": {}}, {"id": 227, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 228, "prop": "charslot", "attributes": {"slot": "l", "posfrom": "-30,0", "posto": "-50,0", "afrom": 1.0, "ato": 0.0, "duration": 1.0, "isblock": "true"}}, {"id": 229, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 230, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#9$1"}}, {"id": 231, "prop": "name", "attributes": {"content": "……", "name": "娜斯提"}, "figure_art": "avg_4212_nasti_1#9$1"}, {"id": 232, "prop": "dialog", "attributes": {}}, {"id": 233, "prop": "Dialog", "attributes": {}}, {"id": 234, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 235, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 236, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 237, "prop": "charslot", "attributes": {}}, {"id": 238, "prop": "Background", "attributes": {"image": "38_g13_trimountlivingroom", "screenadapt": "coverall"}}, {"id": 239, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 240, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 241, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1", "duration": 0.8, "isblock": "true"}}, {"id": 242, "prop": "name", "attributes": {"content": "……請拿好您的權限卡、協議和園區通用聯絡黃頁，再次歡迎您的團隊加入“螺旋槳天堂”！", "name": "工作人員"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 243, "prop": "name", "attributes": {"content": "下一位！請問有什麼可以幫您的？", "name": "工作人員"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 244, "prop": "dialog", "attributes": {}}, {"id": 245, "prop": "charslot", "attributes": {}}, {"id": 246, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 247, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#2$1", "duration": 1.2, "isblock": "true"}}, {"id": 248, "prop": "name", "attributes": {"content": "註銷進駐資格……", "name": "雅斯彭"}, "figure_art": "avg_npc_2041_1#2$1"}, {"id": 249, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1"}}, {"id": 250, "prop": "name", "attributes": {"content": "請問您代表的企業是？", "name": "工作人員"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 251, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#5$1"}}, {"id": 252, "prop": "name", "attributes": {"content": "幸運瘤獸餐飲。", "name": "雅斯彭"}, "figure_art": "avg_npc_2041_1#5$1"}, {"id": 253, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1"}}, {"id": 254, "prop": "name", "attributes": {"content": "一共需要解約八十二名體驗員是嗎？", "name": "工作人員"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 255, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#2$1"}}, {"id": 256, "prop": "name", "attributes": {"content": "對，他們的資料連同我本人的都在這裡了。", "name": "雅斯彭"}, "figure_art": "avg_npc_2041_1#2$1"}, {"id": 257, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1"}}, {"id": 258, "prop": "name", "attributes": {"content": "好的，麻煩稍等一下。", "name": "工作人員"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 259, "prop": "dialog", "attributes": {}}, {"id": 260, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1", "afrom": 1.0, "ato": 0.0, "duration": 0.8, "isblock": "true"}}, {"id": 261, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 262, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#2$1"}}, {"id": 263, "prop": "name", "attributes": {"content": "……", "name": "雅斯彭"}, "figure_art": "avg_npc_2041_1#2$1"}, {"id": 264, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#5$1"}}, {"id": 265, "prop": "name", "attributes": {"content": "唉，我是被影月打到頭了嗎？確信自己參展之後一定能賺回本錢，就僱了八十二個沒有企業工作經驗的門外漢充場面……", "name": "雅斯彭"}, "figure_art": "avg_npc_2041_1#5$1"}, {"id": 266, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#5$1"}}, {"id": 267, "prop": "name", "attributes": {"content": "但這裡的所有企業都是這麼做的，為什麼被淘汰的偏偏是“幸運瘤獸”？", "name": "雅斯彭"}, "figure_art": "avg_npc_2041_1#5$1"}, {"id": 268, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#1$2"}}, {"id": 269, "prop": "name", "attributes": {"content": "就因為處理問題的速度慢了那麼一點點，我上百萬的金券就要打水漂了？開什麼玩笑！", "name": "雅斯彭"}, "figure_art": "avg_npc_2041_1#1$2"}, {"id": 270, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#1$2"}}, {"id": 271, "prop": "name", "attributes": {"content": "他媽的，一隻靴子影月地產到底是怎麼解決那個什麼“立體浮空界樁”的技術問題的？就憑他們那群鞋匠？", "name": "雅斯彭"}, "figure_art": "avg_npc_2041_1#1$2"}, {"id": 272, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1"}}, {"id": 273, "prop": "name", "attributes": {"content": "雅斯彭先生，您的手續已經辦理好了。今天之內，園區的熱線電話依舊會對您開放。", "name": "工作人員"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 274, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#2$1"}}, {"id": 275, "prop": "name", "attributes": {"content": "知道了……", "name": "雅斯彭"}, "figure_art": "avg_npc_2041_1#2$1"}, {"id": 276, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1"}}, {"id": 277, "prop": "name", "attributes": {"content": "但是，如果您像一隻靴子影月地產公司一樣，有一些“特殊”需求……我們也很願意為您處理。", "name": "工作人員"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 278, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#4$1"}}, {"id": 279, "prop": "name", "attributes": {"content": "嗯？你的意思是？", "name": "雅斯彭"}, "figure_art": "avg_npc_2041_1#4$1"}, {"id": 280, "prop": "dialog", "attributes": {}}, {"id": 281, "prop": "charslot", "attributes": {}}, {"id": 282, "prop": "PlaySound", "attributes": {"key": "$d_avg_paper1", "volume": 1.0}}, {"id": 283, "prop": "name", "attributes": {"content": "微笑的工作人員拿出園區內幾乎人手一本的聯絡黃頁，向雅斯彭指出了一個電話號碼。"}}, {"id": 284, "prop": "name", "attributes": {"content": "沒有名稱，沒有地址，這串數字毫不起眼地藏身於幾萬個號碼之中，就像雅斯彭微乎其微的希望。"}}, {"id": 285, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#4$1"}}, {"id": 286, "prop": "name", "attributes": {"content": "只要打這個電話，就能解決我的問題？“幸運瘤獸”就可以不用離開園區？", "name": "雅斯彭"}, "figure_art": "avg_npc_2041_1#4$1"}, {"id": 287, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1"}}, {"id": 288, "prop": "name", "attributes": {"content": "是的。", "name": "工作人員"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 289, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#3$1"}}, {"id": 290, "prop": "name", "attributes": {"content": "那我要取消員工解僱契約，還有企業進駐資格的註銷申請——", "name": "雅斯彭"}, "figure_art": "avg_npc_2041_1#3$1"}, {"id": 291, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1"}}, {"id": 292, "prop": "name", "attributes": {"content": "請放心，我並沒有註銷“幸運瘤獸”的進駐資格，不過體驗員的解約協議無需取消。", "name": "工作人員"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 293, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1"}}, {"id": 294, "prop": "name", "attributes": {"content": "這通熱線會“徹底”解決您的問題，您再也不需要那些人了。", "name": "工作人員"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 295, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#5$1"}}, {"id": 296, "prop": "name", "attributes": {"content": "奇蹟？還是騙局……？", "name": "雅斯彭"}, "figure_art": "avg_npc_2041_1#5$1"}, {"id": 297, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#3$1"}}, {"id": 298, "prop": "name", "attributes": {"content": "不想了，只要能留在這裡，試試看又何妨。", "name": "雅斯彭"}, "figure_art": "avg_npc_2041_1#3$1"}, {"id": 299, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 300, "prop": "dialog", "attributes": {}}, {"id": 301, "prop": "charslot", "attributes": {}}, {"id": 302, "prop": "PlaySound", "attributes": {"key": "$d_avg_telephone", "volume": 1.0}}, {"id": 303, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 304, "prop": "PlaySound", "attributes": {"key": "$d_avg_makephonecall", "volume": 1.0}}, {"id": 305, "prop": "delay", "attributes": {"time": 1.8}}, {"id": 306, "prop": "PlaySound", "attributes": {"key": "$d_avg_telephonebusy", "volume": 1.0}}, {"id": 307, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 308, "prop": "Dialog", "attributes": {}}, {"id": 309, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 310, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 311, "prop": "charslot", "attributes": {}}, {"id": 312, "prop": "Background", "attributes": {"image": "68_g7_airrestaurant", "screenadapt": "coverall"}}, {"id": 313, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 314, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 315, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 316, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2034_1#1$1", "duration": 1.5}}, {"id": 317, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2037_1#1$1", "duration": 1.5, "isblock": "true"}}, {"id": 318, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#6$1"}}, {"id": 319, "prop": "name", "attributes": {"content": "高登長官。", "name": "梅希亞"}, "figure_art": "avg_npc_2037_1#6$1"}, {"id": 320, "prop": "playMusic", "attributes": {"key": "$normal_loop", "volume": 0.6}}, {"id": 321, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#3$1"}}, {"id": 322, "prop": "name", "attributes": {"content": "讓我猜猜，娜斯提雖然將信將疑，但還是收下了我擬定的名單，答應了我的提議，對嗎？", "name": "高登"}, "figure_art": "avg_npc_2034_1#3$1"}, {"id": 323, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#1$1"}}, {"id": 324, "prop": "name", "attributes": {"content": "是的，我去確認了工程部今天的檢修安排，完全按照您指定的順序，沒有任何誤差。", "name": "梅希亞"}, "figure_art": "avg_npc_2037_1#1$1"}, {"id": 325, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#5$1"}}, {"id": 326, "prop": "name", "attributes": {"content": "不過，您是怎麼知道的？", "name": "梅希亞"}, "figure_art": "avg_npc_2037_1#5$1"}, {"id": 327, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#2$1"}}, {"id": 328, "prop": "name", "attributes": {"content": "我不知道她最終的選擇，我只知道我正在經歷自己人生中最輝煌的日子，無論做什麼都會順心如意！", "name": "高登"}, "figure_art": "avg_npc_2034_1#2$1"}, {"id": 329, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#1$1"}}, {"id": 330, "prop": "name", "attributes": {"content": "您看起來確實很高興。", "name": "梅希亞"}, "figure_art": "avg_npc_2037_1#1$1"}, {"id": 331, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#8$1"}}, {"id": 332, "prop": "name", "attributes": {"content": "小小一個萊茵主任還不足以調動我的情緒。", "name": "高登"}, "figure_art": "avg_npc_2034_1#8$1"}, {"id": 333, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#3$1"}}, {"id": 334, "prop": "name", "attributes": {"content": "桌子上那封信，你打開看看。", "name": "高登"}, "figure_art": "avg_npc_2034_1#3$1"}, {"id": 335, "prop": "dialog", "attributes": {}}, {"id": 336, "prop": "PlaySound", "attributes": {"key": "$d_avg_paper2", "volume": 1.0}}, {"id": 337, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#11$1"}}, {"id": 338, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 339, "prop": "name", "attributes": {"content": "“煙酒施術單元以及源石製品管理局向高登·譚農長官發來賀函，恭喜您正式成為‘螺旋槳天堂’的總長官……”", "name": "梅希亞"}, "figure_art": "avg_npc_2037_1#11$1"}, {"id": 340, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#11$1"}}, {"id": 341, "prop": "name", "attributes": {"content": "兩頁紙？我從來沒見過這麼長的賀函。", "name": "梅希亞"}, "figure_art": "avg_npc_2037_1#11$1"}, {"id": 342, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#1$1"}}, {"id": 343, "prop": "name", "attributes": {"content": "六個月前我在哥倫比亞邊境收到的調職郵件裡還只有兩行字。", "name": "高登"}, "figure_art": "avg_npc_2034_1#1$1"}, {"id": 344, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#1$1"}}, {"id": 345, "prop": "name", "attributes": {"content": "人人都覺得管理局的職位是個肥差，但那七年裡，我並沒有在薩米的野人和薩爾貢雨林的土著身上刮到“油水”。", "name": "高登"}, "figure_art": "avg_npc_2034_1#1$1"}, {"id": 346, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#3$1"}}, {"id": 347, "prop": "name", "attributes": {"content": "當時老狐狸看我不順眼，管理局的其他人也不給我好臉色。結果呢？他退休了，我升職了，真是風水輪流轉。", "name": "高登"}, "figure_art": "avg_npc_2034_1#3$1"}, {"id": 348, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#3$1"}}, {"id": 349, "prop": "name", "attributes": {"content": "雖然還是大白天，但這麼高興的日子，就應該——", "name": "高登"}, "figure_art": "avg_npc_2034_1#3$1"}, {"id": 350, "prop": "dialog", "attributes": {}}, {"id": 351, "prop": "PlaySound", "attributes": {"key": "$d_avg_openbeer", "volume": 1.0}}, {"id": 352, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#6$1"}}, {"id": 353, "prop": "delay", "attributes": {"time": 0.3}}, {"id": 354, "prop": "name", "attributes": {"content": "小酌一杯。", "name": "梅希亞"}, "figure_art": "avg_npc_2037_1#6$1"}, {"id": 355, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#1$1"}}, {"id": 356, "prop": "name", "attributes": {"content": "長官，您的香檳。", "name": "梅希亞"}, "figure_art": "avg_npc_2037_1#1$1"}, {"id": 357, "prop": "dialog", "attributes": {}}, {"id": 358, "prop": "PlaySound", "attributes": {"key": "$d_avg_winglssice", "volume": 1.0}}, {"id": 359, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 360, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#3$1"}}, {"id": 361, "prop": "name", "attributes": {"content": "小梅，做得不錯。無論是娜斯提的事還是這杯酒，你在我身邊也算是有些長進，幫你自己也倒一杯吧。", "name": "高登"}, "figure_art": "avg_npc_2034_1#3$1"}, {"id": 362, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#1$1"}}, {"id": 363, "prop": "name", "attributes": {"content": "十分感謝。不過根據秘書準則，工作時間不能飲酒。", "name": "梅希亞"}, "figure_art": "avg_npc_2037_1#1$1"}, {"id": 364, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#1$1"}}, {"id": 365, "prop": "name", "attributes": {"content": "在乎那些幹什麼，你的那本手冊就是我瞎編的。", "name": "高登"}, "figure_art": "avg_npc_2034_1#1$1"}, {"id": 366, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#1$1"}}, {"id": 367, "prop": "name", "attributes": {"content": "那……請您提兩句祝酒詞？", "name": "梅希亞"}, "figure_art": "avg_npc_2037_1#1$1"}, {"id": 368, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#1$1"}}, {"id": 369, "prop": "name", "attributes": {"content": "嗯……六天後的展覽只是個起點，我的開幕致詞必將轟動整個哥倫比亞。", "name": "高登"}, "figure_art": "avg_npc_2034_1#1$1"}, {"id": 370, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#3$1"}}, {"id": 371, "prop": "name", "attributes": {"content": "我會親眼看著所有火箭的外殼都刻上我的頭像，影月都市裡最大的街區也會以我的名字命名。", "name": "高登"}, "figure_art": "avg_npc_2034_1#3$1"}, {"id": 372, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#2$1"}}, {"id": 373, "prop": "name", "attributes": {"content": "萊茵、管理局、特區政府……沒人能壓到我的頭上。只要不出問題，這裡永遠是高登·譚農的“螺旋槳天堂”！", "name": "高登"}, "figure_art": "avg_npc_2034_1#2$1"}, {"id": 374, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#2$1"}}, {"id": 375, "prop": "name", "attributes": {"content": "乾杯！", "name": "高登"}, "figure_art": "avg_npc_2034_1#2$1"}, {"id": 376, "prop": "PlaySound", "attributes": {"key": "$clink", "volume": 1.0}}, {"id": 377, "prop": "dialog", "attributes": {}}, {"id": 378, "prop": "charslot", "attributes": {}}, {"id": 379, "prop": "delay", "attributes": {"time": 1.2}}, {"id": 380, "prop": "PlaySound", "attributes": {"key": "$doorknockquite", "volume": 1.0}}, {"id": 381, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 382, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2034_1#1$1", "focus": "r"}}, {"id": 383, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2037_1#1$1", "focus": "r"}}, {"id": 384, "prop": "name", "attributes": {"content": "誰？趕著來參加我的派對嗎？", "name": "高登"}, "figure_art": "avg_npc_2034_1#1$1"}, {"id": 385, "prop": "dialog", "attributes": {}}, {"id": 386, "prop": "charslot", "attributes": {}}, {"id": 387, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 388, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1000_1#1$1", "posfrom": "250,0", "posto": "0,0", "duration": 1.2, "isblock": "true"}}, {"id": 389, "prop": "name", "attributes": {"content": "您好，請問您是園區總長官嗎？", "name": "陌生的男子"}, "figure_art": "avg_npc_1000_1#1$1"}, {"id": 390, "prop": "name", "attributes": {"content": "我叫奧克里，“螺旋槳天堂”特聘的解說員，來找高登長官報到。", "name": "陌生的男子"}, "figure_art": "avg_npc_1000_1#1$1"}, {"id": 391, "prop": "charslot", "attributes": {}}, {"id": 392, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2034_1#6$1", "focus": "r"}}, {"id": 393, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2037_1#1$1", "focus": "r"}}, {"id": 394, "prop": "name", "attributes": {"content": "……", "name": "高登"}, "figure_art": "avg_npc_2034_1#6$1"}, {"id": 395, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#12$1"}}, {"id": 396, "prop": "name", "attributes": {"content": "……", "name": "梅希亞"}, "figure_art": "avg_npc_2037_1#12$1"}, {"id": 397, "prop": "charslot", "attributes": {"slot": "r", "focus": "r"}}, {"id": 398, "prop": "name", "attributes": {"content": "噗——！", "name": "高登"}, "figure_art": "avg_npc_2034_1#6$1"}, {"id": 399, "prop": "charslot", "attributes": {}}, {"id": 400, "prop": "name", "attributes": {"content": "高登把剛剛喝進嘴裡的香檳全部噴了出來。"}}, {"id": 401, "prop": "dialog", "attributes": {}}, {"id": 402, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 403, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 404, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 405, "prop": "charslot", "attributes": {}}, {"id": 406, "prop": "Background", "attributes": {}}, {"id": 407, "prop": "Image", "attributes": {}}, {"id": 408, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}