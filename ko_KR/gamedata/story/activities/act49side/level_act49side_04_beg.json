sound", "attributes": {"key": "$bodyfalldown3", "channel": "2"}}, {"id": 53, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "-300,0", "posto": "-300,-50", "duration": 0.3}}, {"id": 54, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 55, "prop": "charslot", "attributes": {"slot": "r", "focus": "r"}}, {"id": 56, "prop": "name", "attributes": {"content": "요사스러운 말은 집어치워라!", "name": "염국 국경 군인"}, "figure_art": "avg_npc_2133_1#1$1"}, {"id": 57, "prop": "dialog", "attributes": {}}, {"id": 58, "prop": "charslot", "attributes": {"slot": "m", "action": "shake", "power": 5.0, "times": 30.0, "duration": 0.6, "block": "true"}}, {"id": 59, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "-300,-50", "posto": "-300,0", "duration": 0.6}}, {"id": 60, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 61, "prop": "charslot", "attributes": {"slot": "m", "focus": "m"}}, {"id": 62, "prop": "name", "attributes": {"content": "후우, 후우……", "name": "결연한 산해중 멤버"}}, {"id": 63, "prop": "charslot", "attributes": {"slot": "r", "focus": "r"}}, {"id": 64, "prop": "name", "attributes": {"content": "무기를 내려놓으면 살려는 주겠다!", "name": "염국 국경 군인"}}, {"id": 65, "prop": "charslot", "attributes": {"slot": "m", "focus": "m"}}, {"id": 66, "prop": "name", "attributes": {"content": "무기를 내려놓으라고?", "name": "결연한 산해중 멤버"}}, {"id": 67, "prop": "name", "attributes": {"content": "우리는 염 씨의 핏줄에 알리려는 거다. 쥐서우가 깨어났고, 천년만년 이어질 것이라 생각했던 강산도 이 무한한 천지에 비하면 결국 한낱 꿈에 지나지 않다는 것을!", "name": "결연한 산해중 멤버"}}, {"id": 68, "prop": "name", "attributes": {"content": "온 천지를 주인에게……", "name": "결연한 산해중 멤버"}}, {"id": 69, "prop": "dialog", "attributes": {}}, {"id": 70, "prop": "playsound", "attributes": {"key": "$d_avg_knife", "channel": "1"}}, {"id": 71, "prop": "charslot", "attributes": {"slot": "r", "posfrom": "100,0", "posto": "-300,0", "duration": 0.3}}, {"id": 72, "prop": "playsound", "attributes": {"key": "$d_avg_spear"}}, {"id": 73, "prop": "Blocker", "attributes": {"a": 0.2, "r": 1.0, "g": 0.0, "b": 0.0, "fadet